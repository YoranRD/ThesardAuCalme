---
import { getMascotSrc, type MascotAction } from "../lib/brand-mascots";

interface Props {
  action?: MascotAction;
  size?: "sm" | "md" | "lg";
  alt?: string;
  className?: string;
}

const {
  action = "default",
  size = "md",
  alt = "",
  className = ""
} = Astro.props;

const src = getMascotSrc(action);

const sizeMap = {
  sm: { width: 58, height: 58 },
  md: { width: 106, height: 106 },
  lg: { width: 220, height: 220 }
};

const dimensions = sizeMap[size];
---

{
  src && (
    <span class:list={{ mascot: true, [`size-${size}`]: true, [className]: Boolean(className) }}>
      <img
        src={src}
        alt={alt}
        width={dimensions.width}
        height={dimensions.height}
        loading="lazy"
        decoding="async"
        aria-hidden={alt.length === 0 ? "true" : undefined}
      />
    </span>
  )
}

<style>
  .mascot {
    display: inline-flex;
    border: 1px solid color-mix(in srgb, var(--accent) 24%, var(--border));
    border-radius: var(--radius-2);
    background: linear-gradient(145deg, #f9f8f2 0%, #ecefe7 100%);
    box-shadow: 0 10px 24px rgba(23, 27, 30, 0.08);
    overflow: hidden;
  }

  .mascot img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .mascot.size-sm {
    width: 58px;
    height: 58px;
  }

  .mascot.size-md {
    width: 106px;
    height: 106px;
  }

  .mascot.size-lg {
    width: 220px;
    height: 220px;
  }
</style>
