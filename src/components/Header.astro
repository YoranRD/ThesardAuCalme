---
import { activeBasePath, brandDisplayName } from "../config/site";
import { withBase } from "../lib/links";

const logoModule = import.meta.glob("../assets/brand/logo.svg", {
  eager: true,
  import: "default",
  query: "?url"
}) as Record<string, string>;

const mascotModule = import.meta.glob("../assets/brand/mascot.svg", {
  eager: true,
  import: "default",
  query: "?url"
}) as Record<string, string>;

const logoSrc = logoModule["../assets/brand/logo.svg"];
const mascotSrc = mascotModule["../assets/brand/mascot.svg"];

const navItems = [
  { href: "/", label: "Accueil" },
  { href: "/start/", label: "Commencer" },
  { href: "/youtube/", label: "YouTube" },
  { href: "/videos/", label: "Vidéos" },
  { href: "/guides/", label: "Guides" },
  { href: "/outils/", label: "Outils" },
  { href: "/articles/", label: "Articles" },
  { href: "/ressources/", label: "Ressources" },
  { href: "/recherche/", label: "Recherche" },
  { href: "/a-propos/", label: "À propos" },
  { href: "/contact/", label: "Contact" }
];

const escapeRegExp = (value: string): string => value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
const currentPath = Astro.url.pathname;
const pathWithoutBase =
  activeBasePath === "/"
    ? currentPath
    : currentPath.replace(new RegExp(`^${escapeRegExp(activeBasePath)}`), "") || "/";

const isActive = (href: string): boolean => {
  if (href === "/") {
    return pathWithoutBase === "/";
  }
  return pathWithoutBase.startsWith(href);
};
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand-link" href={withBase("/")} aria-label="Retour à l'accueil">
      {
        mascotSrc && (
          <img src={mascotSrc} alt="" width="42" height="42" loading="eager" decoding="async" aria-hidden="true" />
        )
      }
      {
        logoSrc && (
          <img
            class="brand-logo"
            src={logoSrc}
            alt=""
            width="34"
            height="34"
            loading="eager"
            decoding="async"
            aria-hidden="true"
          />
        )
      }
      <span class="brand-name">{brandDisplayName}</span>
    </a>

    <nav aria-label="Navigation principale">
      <ul class="nav-list">
        {
          navItems.map((item) => (
            <li>
              <a class={isActive(item.href) ? "active" : undefined} href={withBase(item.href)}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: rgba(248, 246, 241, 0.95);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 30;
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 0.52rem;
    text-decoration: none;
  }

  .brand-logo {
    border-radius: 0.35rem;
  }

  .brand-name {
    font-family: "Iowan Old Style", "Palatino Linotype", Palatino, serif;
    font-size: 1.15rem;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .nav-list {
    display: flex;
    list-style: none;
    gap: 0.3rem;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .nav-list a {
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.33rem 0.75rem;
    font-size: 0.93rem;
    color: var(--text-soft);
    transition: 150ms ease;
  }

  .nav-list a:hover,
  .nav-list a.active {
    color: var(--accent);
    border-color: var(--border);
    background: #fff;
  }

  @media (max-width: 900px) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .nav-list {
      justify-content: flex-start;
    }
  }
</style>
