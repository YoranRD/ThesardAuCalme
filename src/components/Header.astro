---
import { activeBasePath, brandDisplayName } from "../config/site";
import { hasBrandMascot, brandLogoSrc, brandMascotSrc } from "../lib/brand";
import { withBase } from "../lib/links";

const primaryNav = [
  { href: "/start/", label: "Commencer" },
  { href: "/outils/", label: "Outils" },
  { href: "/youtube/", label: "YouTube" },
  { href: "/articles/", label: "Blog" }
];

const explorerGroups = [
  {
    title: "Démarrer",
    description: "Feuilles de route et bases de départ.",
    items: [
      { href: "/start/", label: "Start" },
      { href: "/roadmaps/", label: "Roadmaps" },
      { href: "/downloads/", label: "Pack gratuit" },
      { href: "/recherche/", label: "Recherche" },
      { href: "/blog/", label: "Blog" }
    ]
  },
  {
    title: "Contenu",
    description: "Parcours vidéo, articles et séries.",
    items: [
      { href: "/videos/", label: "Vidéos" },
      { href: "/articles/", label: "Articles" },
      { href: "/guides/", label: "Guides" },
      { href: "/series/", label: "Séries" },
      { href: "/playlists/", label: "Playlists" },
      { href: "/youtube/", label: "Hub YouTube" }
    ]
  },
  {
    title: "Outils",
    description: "Toolbox, avis, stacks et comparatifs.",
    items: [
      { href: "/outils/", label: "Toolbox" },
      { href: "/outils/avis/", label: "Avis outils" },
      { href: "/stacks/", label: "Stacks" },
      { href: "/ressources/", label: "Ressources" },
      { href: "/outils/#top-categories", label: "Top catégories" }
    ]
  },
  {
    title: "Communauté",
    description: "Cadence, défis et entraide.",
    items: [
      { href: "/communaute/", label: "Hub" },
      { href: "/communaute/defis/", label: "Défis" },
      { href: "/communaute/kit/", label: "Kit" },
      { href: "/newsletter/", label: "Newsletter" },
      { href: "/contact/", label: "Contact" }
    ]
  }
];

const explorerPaths = explorerGroups.flatMap((group) => group.items.map((item) => item.href));

const escapeRegExp = (value: string): string => value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
const currentPath = Astro.url.pathname;
const pathWithoutBase =
  activeBasePath === "/"
    ? currentPath
    : currentPath.replace(new RegExp(`^${escapeRegExp(activeBasePath)}`), "") || "/";

const isActive = (href: string): boolean => {
  const normalizedHref = href.replace(/#.*/, "");
  if (normalizedHref === "/") {
    return pathWithoutBase === "/";
  }
  return pathWithoutBase.startsWith(normalizedHref);
};

const isExplorerActive = explorerPaths.some((href) => isActive(href));
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand-link" href={withBase("/")} aria-label="Retour à l'accueil">
      {
        hasBrandMascot && brandMascotSrc && (
          <img class="brand-mascot" src={brandMascotSrc} alt="" width="42" height="42" loading="eager" decoding="async" aria-hidden="true" />
        )
      }
      {
        brandLogoSrc && (
          <img class="brand-logo" src={brandLogoSrc} alt="" width="32" height="32" loading="eager" decoding="async" aria-hidden="true" />
        )
      }
      <span class="brand-name">{brandDisplayName}</span>
    </a>

    <nav aria-label="Navigation principale" class="site-nav">
      <ul class="nav-list">
        {
          primaryNav.map((item) => (
            <li>
              <a class={isActive(item.href) ? "active" : undefined} href={withBase(item.href)}>
                {item.label}
              </a>
            </li>
          ))
        }

        <li class="header-search desktop-search">
          <form action={withBase("/recherche/")} method="get">
            <label class="sr-only" for="header-search-input">Recherche globale</label>
            <input id="header-search-input" type="search" name="q" placeholder="Rechercher..." />
          </form>
        </li>

        <li>
          <button class="button button-ghost palette-trigger" type="button" data-open-search-palette>
            Rechercher
            <span class="palette-kbd"><kbd>⌘</kbd><kbd>K</kbd></span>
          </button>
        </li>

        <li class="explorer-item">
          <details class="explorer-details" data-explorer-details>
            <summary class:list={{ active: isExplorerActive }}>Explorer</summary>
            <div class="explorer-panel" role="region" aria-label="Explorer les sections">
              <div class="explorer-desktop-grid">
                {
                  explorerGroups.map((group) => (
                    <section class="explorer-group">
                      <p>{group.title}</p>
                      <span class="small muted">{group.description}</span>
                      <ul>
                        {
                          group.items.map((entry) => (
                            <li><a href={withBase(entry.href)}>{entry.label}</a></li>
                          ))
                        }
                      </ul>
                    </section>
                  ))
                }
              </div>

              <div class="explorer-mobile-accordion">
                {
                  explorerGroups.map((group) => (
                    <details class="mobile-group">
                      <summary>{group.title}</summary>
                      <ul>
                        {
                          group.items.map((entry) => (
                            <li><a href={withBase(entry.href)}>{entry.label}</a></li>
                          ))
                        }
                      </ul>
                    </details>
                  ))
                }
              </div>
            </div>
          </details>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  (() => {
    const details = document.querySelector("[data-explorer-details]");
    if (!(details instanceof HTMLDetailsElement)) {
      return;
    }

    const summary = details.querySelector("summary");
    const desktopMediaQuery = window.matchMedia("(min-width: 981px)");
    let closeTimer = null;

    const closeExplorer = () => {
      if (closeTimer !== null) {
        window.clearTimeout(closeTimer);
        closeTimer = null;
      }
      details.open = false;
    };

    const openExplorer = () => {
      if (closeTimer !== null) {
        window.clearTimeout(closeTimer);
        closeTimer = null;
      }
      details.open = true;
    };

    const scheduleClose = () => {
      if (closeTimer !== null) {
        window.clearTimeout(closeTimer);
      }
      closeTimer = window.setTimeout(() => {
        if (!details.matches(":focus-within") && !details.matches(":hover")) {
          details.open = false;
        }
      }, 170);
    };

    if (summary instanceof HTMLElement) {
      summary.addEventListener("click", (event) => {
        if (!desktopMediaQuery.matches) {
          return;
        }
        event.preventDefault();
        if (details.open) {
          closeExplorer();
        } else {
          openExplorer();
        }
      });
    }

    details.addEventListener("mouseenter", () => {
      if (!desktopMediaQuery.matches) {
        return;
      }
      openExplorer();
    });

    details.addEventListener("mouseleave", () => {
      if (!desktopMediaQuery.matches) {
        return;
      }
      scheduleClose();
    });

    details.addEventListener("focusin", () => {
      if (!desktopMediaQuery.matches) {
        return;
      }
      openExplorer();
    });

    details.addEventListener("focusout", () => {
      if (!desktopMediaQuery.matches) {
        return;
      }
      scheduleClose();
    });

    document.addEventListener("click", (event) => {
      if (!details.open) {
        return;
      }

      const target = event.target;
      if (!(target instanceof Node)) {
        return;
      }

      if (!details.contains(target)) {
        closeExplorer();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && details.open) {
        closeExplorer();
        if (summary instanceof HTMLElement) {
          summary.focus();
        }
      }
    });
  })();
</script>

<style>
  .site-header {
    border-bottom: 1px solid var(--brand-border);
    background: color-mix(in srgb, var(--brand-bg) 90%, #ffffff 10%);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 45;
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.9rem;
    padding: 0.62rem 0;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand-mascot,
  .brand-logo {
    border-radius: 0.4rem;
  }

  .brand-name {
    font-family: var(--font-serif);
    font-size: 1.06rem;
    color: var(--brand-text);
    white-space: nowrap;
  }

  .site-nav {
    width: 100%;
  }

  .nav-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 0.24rem;
  }

  .nav-list a,
  .explorer-details summary {
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: var(--radius-pill);
    padding: 0.35rem 0.72rem;
    font-size: 0.9rem;
    color: var(--brand-muted);
    transition: 160ms ease;
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    background: transparent;
    user-select: none;
  }

  .nav-list a:hover,
  .nav-list a.active,
  .explorer-details summary:hover,
  .explorer-details summary.active,
  .explorer-details[open] summary {
    color: var(--brand-accent);
    border-color: var(--brand-border);
    background: #fff;
  }

  .desktop-search {
    margin-inline: 0.25rem;
  }

  .desktop-search input {
    width: min(220px, 22vw);
    border: 1px solid var(--brand-border);
    border-radius: var(--radius-pill);
    padding: 0.43rem 0.75rem;
    font: inherit;
    font-size: 0.88rem;
    background: #fff;
    color: var(--brand-text);
  }

  .palette-trigger {
    gap: 0.42rem;
    padding-inline: 0.7rem;
    border-color: var(--brand-border);
  }

  .palette-kbd {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
  }

  .palette-kbd kbd {
    border: 1px solid var(--brand-border);
    border-bottom-width: 2px;
    border-radius: 0.33rem;
    background: #fff;
    padding: 0.04rem 0.28rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--brand-muted);
  }

  .explorer-item {
    position: relative;
  }

  .explorer-details summary {
    list-style: none;
  }

  .explorer-details summary::-webkit-details-marker {
    display: none;
  }

  .explorer-panel {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    width: min(860px, 94vw);
    border: 1px solid var(--brand-border);
    border-radius: var(--radius-3);
    background: var(--brand-surface);
    box-shadow: var(--shadow-3);
    padding: 0.9rem;
    transform-origin: top right;
    animation: explorer-in 180ms ease;
  }

  @keyframes explorer-in {
    from {
      opacity: 0;
      transform: translateY(-6px) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .explorer-desktop-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .explorer-group {
    display: grid;
    gap: 0.35rem;
  }

  .explorer-group p {
    margin: 0;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--brand-accent);
    font-weight: 700;
  }

  .explorer-group ul,
  .explorer-mobile-accordion ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.1rem;
  }

  .explorer-group a,
  .explorer-mobile-accordion a {
    border: 0;
    border-radius: var(--radius-1);
    padding: 0.2rem 0.3rem;
    color: var(--brand-muted);
  }

  .explorer-group a:hover,
  .explorer-mobile-accordion a:hover {
    background: #f3f7f8;
    color: var(--brand-text);
  }

  .explorer-mobile-accordion {
    display: none;
  }

  .mobile-group {
    border: 1px solid var(--brand-border);
    border-radius: var(--radius-2);
    padding: 0.5rem;
    background: #fff;
  }

  .mobile-group summary {
    cursor: pointer;
    color: var(--brand-text);
    font-weight: 600;
  }

  .mobile-group ul {
    margin-top: 0.42rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    border: 0;
    padding: 0;
    clip: rect(0 0 0 0);
    overflow: hidden;
    white-space: nowrap;
  }

  @media (max-width: 1160px) {
    .desktop-search {
      display: none;
    }
  }

  @media (max-width: 980px) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .site-nav {
      width: 100%;
    }

    .nav-list {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
    }

    .nav-list a,
    .explorer-details summary,
    .palette-trigger {
      width: 100%;
      justify-content: space-between;
      border-color: var(--brand-border);
      background: #fff;
    }

    .explorer-item {
      width: 100%;
    }

    .explorer-panel {
      position: static;
      width: 100%;
      margin-top: 0.4rem;
      box-shadow: none;
    }

    .explorer-desktop-grid {
      display: none;
    }

    .explorer-mobile-accordion {
      display: grid;
      gap: 0.55rem;
    }
  }
</style>
