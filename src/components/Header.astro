---
import { activeBasePath, brandDisplayName } from "../config/site";
import { hasBrandMascot, brandLogoSrc, brandMascotSrc } from "../lib/brand";
import { withBase } from "../lib/links";

const primaryNav = [
  { href: "/start/", label: "Commencer" },
  { href: "/outils/", label: "Toolbox" },
  { href: "/youtube/", label: "YouTube" },
  { href: "/articles/", label: "Articles" }
];

const explorerGroups = [
  {
    title: "Démarrer",
    items: [
      { href: "/start/", label: "Start" },
      { href: "/roadmaps/", label: "Roadmaps" },
      { href: "/downloads/", label: "Downloads" }
    ]
  },
  {
    title: "Contenu",
    items: [
      { href: "/videos/", label: "Vidéos" },
      { href: "/articles/", label: "Articles" },
      { href: "/guides/", label: "Guides" },
      { href: "/series/", label: "Séries" }
    ]
  },
  {
    title: "Outils",
    items: [
      { href: "/outils/", label: "Toolbox" },
      { href: "/outils/avis/", label: "Avis" },
      { href: "/ressources/", label: "Ressources" }
    ]
  },
  {
    title: "Communauté",
    items: [
      { href: "/communaute/", label: "Hub" },
      { href: "/communaute/defis/", label: "Défis" }
    ]
  }
];

const explorerPaths = explorerGroups.flatMap((group) => group.items.map((item) => item.href));

const escapeRegExp = (value: string): string => value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
const currentPath = Astro.url.pathname;
const pathWithoutBase =
  activeBasePath === "/"
    ? currentPath
    : currentPath.replace(new RegExp(`^${escapeRegExp(activeBasePath)}`), "") || "/";

const isActive = (href: string): boolean => {
  if (href === "/") {
    return pathWithoutBase === "/";
  }
  return pathWithoutBase.startsWith(href);
};

const isExplorerActive = explorerPaths.some((href) => isActive(href));
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand-link" href={withBase("/")} aria-label="Retour à l'accueil">
      {
        hasBrandMascot && brandMascotSrc && (
          <img class="brand-mascot" src={brandMascotSrc} alt="" width="42" height="42" loading="eager" decoding="async" aria-hidden="true" />
        )
      }
      {
        brandLogoSrc && (
          <img class="brand-logo" src={brandLogoSrc} alt="" width="32" height="32" loading="eager" decoding="async" aria-hidden="true" />
        )
      }
      <span class="brand-name">{brandDisplayName}</span>
    </a>

    <nav aria-label="Navigation principale" class="site-nav">
      <ul class="nav-list">
        {
          primaryNav.map((item) => (
            <li>
              <a class={isActive(item.href) ? "active" : undefined} href={withBase(item.href)}>
                {item.label}
              </a>
            </li>
          ))
        }

        <li class="explorer-item">
          <details class="explorer-details">
            <summary class:list={{ active: isExplorerActive }}>Explorer</summary>
            <div class="explorer-panel">
              {
                explorerGroups.map((group) => (
                  <section class="explorer-group">
                    <p>{group.title}</p>
                    <ul>
                      {
                        group.items.map((entry) => (
                          <li><a href={withBase(entry.href)}>{entry.label}</a></li>
                        ))
                      }
                    </ul>
                  </section>
                ))
              }
            </div>
          </details>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--brand-border);
    background: rgba(248, 246, 241, 0.95);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 35;
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.8rem;
    padding: 0.65rem 0;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand-mascot,
  .brand-logo {
    border-radius: 0.4rem;
  }

  .brand-name {
    font-family: "Iowan Old Style", "Palatino Linotype", Palatino, serif;
    font-size: 1.07rem;
    letter-spacing: -0.01em;
    color: var(--brand-text);
    white-space: nowrap;
  }

  .site-nav {
    width: 100%;
  }

  .nav-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 0.3rem;
  }

  .nav-list a,
  .explorer-details summary {
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: var(--radius-pill);
    padding: 0.33rem 0.75rem;
    font-size: 0.91rem;
    color: var(--brand-muted);
    transition: 150ms ease;
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    background: transparent;
    user-select: none;
  }

  .nav-list a:hover,
  .nav-list a.active,
  .explorer-details summary:hover,
  .explorer-details summary.active,
  .explorer-details[open] summary {
    color: var(--brand-accent);
    border-color: var(--brand-border);
    background: #fff;
  }

  .explorer-item {
    position: relative;
  }

  .explorer-details summary {
    list-style: none;
  }

  .explorer-details summary::-webkit-details-marker {
    display: none;
  }

  .explorer-panel {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    width: min(760px, 90vw);
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.7rem;
    padding: 0.9rem;
    border: 1px solid var(--brand-border);
    border-radius: var(--radius-3);
    background: var(--brand-surface);
    box-shadow: var(--shadow-3);
  }

  .explorer-group {
    display: grid;
    gap: 0.35rem;
  }

  .explorer-group p {
    margin: 0;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--brand-accent);
    font-weight: 700;
  }

  .explorer-group ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.15rem;
  }

  .explorer-group a {
    border: 0;
    border-radius: var(--radius-1);
    padding: 0.2rem 0.3rem;
    color: var(--brand-muted);
  }

  .explorer-group a:hover {
    background: #f6f0e6;
    color: var(--brand-text);
  }

  @media (max-width: 980px) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .site-nav {
      width: 100%;
    }

    .nav-list {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
    }

    .nav-list a,
    .explorer-details summary {
      width: 100%;
      justify-content: space-between;
      border-color: var(--brand-border);
      background: #fff;
    }

    .explorer-item {
      width: 100%;
    }

    .explorer-panel {
      position: static;
      width: 100%;
      margin-top: 0.4rem;
      grid-template-columns: 1fr;
      box-shadow: none;
    }
  }
</style>
