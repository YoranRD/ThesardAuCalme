---
import wordmark from "../assets/brand/wordmark.svg";
import mascot from "../assets/brand/mascot.svg";
import { activeBasePath } from "../config/site";
import { withBase } from "../lib/links";

const navItems = [
  { href: "/", label: "Accueil" },
  { href: "/start/", label: "Commencer" },
  { href: "/videos/", label: "Vidéos" },
  { href: "/guides/", label: "Guides" },
  { href: "/articles/", label: "Articles" },
  { href: "/ressources/", label: "Ressources" },
  { href: "/recherche/", label: "Recherche" },
  { href: "/a-propos/", label: "À propos" },
  { href: "/contact/", label: "Contact" }
];

const escapeRegExp = (value: string): string => value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
const currentPath = Astro.url.pathname;
const pathWithoutBase =
  activeBasePath === "/"
    ? currentPath
    : currentPath.replace(new RegExp(`^${escapeRegExp(activeBasePath)}`), "") || "/";

const isActive = (href: string): boolean => {
  if (href === "/") {
    return pathWithoutBase === "/";
  }
  return pathWithoutBase.startsWith(href);
};
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand-link" href={withBase("/")} aria-label="Retour à l'accueil">
      <img src={mascot.src} alt="Mascotte Thésard Au Calme" width="44" height="44" loading="eager" />
      <img src={wordmark.src} alt="Thésard Au Calme" width="250" height="46" loading="eager" />
    </a>

    <nav aria-label="Navigation principale">
      <ul class="nav-list">
        {
          navItems.map((item) => (
            <li>
              <a class={isActive(item.href) ? "active" : undefined} href={withBase(item.href)}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: rgba(248, 246, 241, 0.95);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 30;
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
  }

  .nav-list {
    display: flex;
    list-style: none;
    gap: 0.3rem;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .nav-list a {
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.33rem 0.75rem;
    font-size: 0.93rem;
    color: var(--text-soft);
    transition: 150ms ease;
  }

  .nav-list a:hover,
  .nav-list a.active {
    color: var(--accent);
    border-color: var(--border);
    background: #fff;
  }

  @media (max-width: 900px) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .brand-link img:nth-child(2) {
      width: 205px;
      height: auto;
    }

    .nav-list {
      justify-content: flex-start;
    }
  }
</style>
