---
import type { CollectionEntry } from "astro:content";
import { withBase } from "../lib/links";
import TagList from "./TagList.astro";

interface Props {
  video: CollectionEntry<"videos">;
}

const { video } = Astro.props;
const publicationDate = video.data.date.toLocaleDateString("fr-FR", {
  day: "2-digit",
  month: "long",
  year: "numeric"
});
---

<article class="card video-card">
  <p class="small muted">{publicationDate} • {video.data.durationMin} min</p>
  <h3><a href={withBase(`/videos/${video.slug}/`)}>{video.data.title}</a></h3>
  <p>{video.data.summary}</p>
  <TagList tags={video.data.tags} />
  <a class="button button-secondary" href={withBase(`/videos/${video.slug}/`)}>Voir la fiche vidéo</a>
</article>

<style>
  .video-card {
    display: grid;
    gap: 0.75rem;
  }

  .video-card h3 {
    margin-bottom: 0.2rem;
  }

  .video-card a {
    text-decoration: none;
  }
</style>
