---
interface TocHeading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: TocHeading[];
  title?: string;
  minDepth?: number;
  maxDepth?: number;
  mobileCollapsible?: boolean;
}

const {
  headings,
  title = "Sommaire",
  minDepth = 2,
  maxDepth = 3,
  mobileCollapsible = false
} = Astro.props;

const visibleHeadings = headings.filter((heading) => heading.depth >= minDepth && heading.depth <= maxDepth);
---

{
  visibleHeadings.length > 0 && (
    <aside class:list={{ surface: true, "toc-block": true, "toc-mobile-collapsible": mobileCollapsible }} aria-label={title} data-toc-block>
      {
        mobileCollapsible ? (
          <>
            <div class="toc-desktop-shell">
              <p class="toc-title">{title}</p>
              <ol>
                {
                  visibleHeadings.map((heading) => (
                    <li class={`depth-${heading.depth}`}>
                      <a href={`#${heading.slug}`} data-toc-link={heading.slug}>{heading.text}</a>
                    </li>
                  ))
                }
              </ol>
            </div>

            <details class="toc-mobile-shell">
              <summary>{title}</summary>
              <ol>
                {
                  visibleHeadings.map((heading) => (
                    <li class={`depth-${heading.depth}`}>
                      <a href={`#${heading.slug}`} data-toc-link={heading.slug}>{heading.text}</a>
                    </li>
                  ))
                }
              </ol>
            </details>
          </>
        ) : (
          <>
            <p class="toc-title">{title}</p>
            <ol>
              {
                visibleHeadings.map((heading) => (
                  <li class={`depth-${heading.depth}`}>
                    <a href={`#${heading.slug}`} data-toc-link={heading.slug}>{heading.text}</a>
                  </li>
                ))
              }
            </ol>
          </>
        )
      }
    </aside>
  )
}

<script is:inline>
  const tocBlocks = Array.from(document.querySelectorAll("[data-toc-block]"));
  const desktopMediaQuery = window.matchMedia("(min-width: 1080px)");

  if (desktopMediaQuery.matches) {
    tocBlocks.forEach((tocBlock) => {
      if (tocBlock.getAttribute("data-toc-ready") === "true") {
        return;
      }
      tocBlock.setAttribute("data-toc-ready", "true");

      const tocLinks = Array.from(tocBlock.querySelectorAll("[data-toc-link]"));
      if (tocLinks.length === 0) {
        return;
      }

      const uniqueTargetEntries = new Map();

      tocLinks.forEach((link) => {
        const slug = link.getAttribute("data-toc-link");
        if (!slug || uniqueTargetEntries.has(slug)) {
          return;
        }
        const section = document.getElementById(slug);
        if (!section) {
          return;
        }
        uniqueTargetEntries.set(slug, { section, slug });
      });

      const targetEntries = [...uniqueTargetEntries.values()];
      if (targetEntries.length === 0) {
        return;
      }

      const setActiveSlug = (slug) => {
        tocLinks.forEach((link) => {
          const isActive = link.getAttribute("data-toc-link") === slug;
          link.classList.toggle("is-active", isActive);
          if (isActive) {
            link.setAttribute("aria-current", "true");
          } else {
            link.removeAttribute("aria-current");
          }
        });
      };

      setActiveSlug(targetEntries[0].slug);

      const intersectionObserver = new IntersectionObserver(
        (entries) => {
          const visibleEntries = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

          if (visibleEntries.length > 0) {
            setActiveSlug(visibleEntries[0].target.id);
            return;
          }

          const passedEntries = targetEntries
            .filter((entry) => entry.section.getBoundingClientRect().top <= 160)
            .sort((a, b) => a.section.getBoundingClientRect().top - b.section.getBoundingClientRect().top);

          if (passedEntries.length > 0) {
            setActiveSlug(passedEntries[passedEntries.length - 1].slug);
          }
        },
        {
          root: null,
          rootMargin: "-15% 0px -65% 0px",
          threshold: [0, 0.25, 0.5, 1]
        }
      );

      targetEntries.forEach((entry) => {
        intersectionObserver.observe(entry.section);
      });
    });
  }
</script>

<style>
  .toc-block {
    padding: 1rem 1.1rem;
    border-radius: var(--radius-sm);
  }

  .toc-title {
    margin: 0 0 0.65rem;
    font-weight: 700;
    color: var(--text);
  }

  .toc-block ol {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.34rem;
  }

  .toc-block li {
    color: var(--text-soft);
  }

  .toc-block li.depth-3 {
    margin-left: 0.55rem;
  }

  .toc-block a {
    color: inherit;
    text-decoration: none;
  }

  .toc-block a:hover {
    text-decoration: underline;
  }

  .toc-block a.is-active {
    color: var(--accent);
    font-weight: 600;
  }

  .toc-mobile-shell {
    display: none;
  }

  .toc-mobile-shell summary {
    cursor: pointer;
    font-weight: 700;
    color: var(--brand-text);
  }

  .toc-mobile-shell[open] summary {
    margin-bottom: 0.6rem;
  }

  @media (max-width: 1079px) {
    .toc-mobile-collapsible .toc-desktop-shell {
      display: none;
    }

    .toc-mobile-collapsible .toc-mobile-shell {
      display: block;
    }
  }

  @media (min-width: 1080px) {
    .toc-block {
      position: sticky;
      top: 6.5rem;
    }
  }
</style>
