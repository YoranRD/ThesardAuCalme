---
interface Props {
  title: string;
  variant?: "key-takeaways" | "warning" | "tip";
  items?: string[];
}

const { title, variant = "tip", items = [] } = Astro.props;

const variantIcon: Record<"key-takeaways" | "warning" | "tip", string> = {
  "key-takeaways": "◆",
  warning: "▲",
  tip: "✦"
};
---

<section class={`callout-box callout-${variant}`}>
  <p class="callout-title"><span aria-hidden="true">{variantIcon[variant]}</span> {title}</p>
  {
    items.length > 0 && (
      <ul>
        {items.slice(0, 3).map((item) => <li>{item}</li>)}
      </ul>
    )
  }
  <slot />
</section>

<style>
  .callout-box {
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--border));
    border-radius: var(--radius-2);
    padding: 1rem;
    display: grid;
    gap: 0.5rem;
    background: linear-gradient(145deg, #f8f5ee 0%, #eeefe6 100%);
    box-shadow: 0 8px 20px rgba(26, 31, 33, 0.08);
  }

  .callout-title {
    margin: 0;
    font-weight: 700;
    color: var(--brand-text);
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .callout-box ul {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--text-soft);
    display: grid;
    gap: 0.32rem;
  }

  .callout-warning {
    background: color-mix(in srgb, var(--accent-2) 10%, #fff8f5);
    border-color: color-mix(in srgb, var(--accent-2) 36%, var(--border));
  }

  .callout-warning .callout-title {
    color: #7c3f29;
  }

  .callout-tip {
    background: color-mix(in srgb, var(--accent-soft) 62%, #fff);
    border-color: color-mix(in srgb, var(--accent) 28%, var(--border));
  }

  .callout-tip .callout-title {
    color: #2f6048;
  }

  .callout-key-takeaways {
    border-left: 4px solid var(--accent);
    background: linear-gradient(135deg, #f9f7f0 0%, #e8efe8 62%, #efe6da 100%);
  }

  .callout-key-takeaways .callout-title {
    color: color-mix(in srgb, var(--accent) 75%, var(--accent-2));
  }
</style>
