---
import type { CollectionEntry } from "astro:content";
import TagList from "./TagList.astro";

interface Props {
  guide: CollectionEntry<"guides">;
}

const { guide } = Astro.props;
const publicationDate = guide.data.date.toLocaleDateString("fr-FR", {
  day: "2-digit",
  month: "long",
  year: "numeric"
});
---

<article class="card guide-card">
  <p class="small muted">{publicationDate}</p>
  <h3><a href={`/guides/${guide.slug}/`}>{guide.data.title}</a></h3>
  <p>{guide.data.summary}</p>
  <TagList tags={guide.data.tags} />
  <a class="button button-secondary" href={`/guides/${guide.slug}/`}>Lire le guide</a>
</article>

<style>
  .guide-card {
    display: grid;
    gap: 0.75rem;
  }

  .guide-card h3 {
    margin-bottom: 0.2rem;
  }

  .guide-card a {
    text-decoration: none;
  }
</style>
