---
import type { CollectionEntry } from "astro:content";
import { withBase } from "../lib/links";
import TagList from "./TagList.astro";

interface Props {
  guide: CollectionEntry<"guides">;
}

const { guide } = Astro.props;
const referenceDate = guide.data.updated ?? guide.data.date;
const publicationDate = referenceDate.toLocaleDateString("fr-FR", {
  day: "2-digit",
  month: "long",
  year: "numeric"
});
const datePrefix = guide.data.updated ? "Mis à jour" : "Publié";
---

<article class="card guide-card">
  <p class="small muted">{datePrefix} le {publicationDate}</p>
  <h3><a href={withBase(`/guides/${guide.slug}/`)}>{guide.data.title}</a></h3>
  <p>{guide.data.summary}</p>
  <TagList tags={guide.data.tags} />
  <a class="button button-secondary" href={withBase(`/guides/${guide.slug}/`)}>Lire le guide</a>
</article>

<style>
  .guide-card {
    display: grid;
    gap: 0.75rem;
  }

  .guide-card h3 {
    margin-bottom: 0.2rem;
  }

  .guide-card a {
    text-decoration: none;
  }
</style>
