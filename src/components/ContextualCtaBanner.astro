---
import { withBase } from "../lib/links";
---

<section class="surface contextual-cta" data-contextual-cta hidden>
  <div class="cta-text">
    <p class="eyebrow">Pack gratuit</p>
    <p class="small">Checklist pratique + accès toolbox + espace communauté pour garder une cadence stable.</p>
  </div>
  <div class="cta-actions">
    <a class="button button-primary" href={withBase("/downloads/")}>Pack gratuit</a>
    <a class="button button-secondary" href={withBase("/outils/")}>Toolbox</a>
    <a class="button button-secondary" href={withBase("/communaute/")}>Communauté</a>
    <button type="button" class="cta-dismiss" data-contextual-cta-dismiss>Masquer</button>
  </div>
</section>

<script is:inline>
  (() => {
    const banner = document.querySelector("[data-contextual-cta]");
    const dismissButton = document.querySelector("[data-contextual-cta-dismiss]");
    if (!banner || !dismissButton) {
      return;
    }

    const storageKey = "tac-contextual-cta-last-shown-at";
    const cooldownMs = 7 * 24 * 60 * 60 * 1000;

    const getLastShownAt = () => {
      try {
        const raw = window.localStorage.getItem(storageKey);
        return raw ? Number(raw) : 0;
      } catch {
        return 0;
      }
    };

    const setLastShownAt = (timestamp) => {
      try {
        window.localStorage.setItem(storageKey, String(timestamp));
      } catch {
        // no-op when storage is unavailable
      }
    };

    const isCooldownActive = () => {
      const lastShownAt = getLastShownAt();
      if (!Number.isFinite(lastShownAt) || lastShownAt <= 0) {
        return false;
      }
      return Date.now() - lastShownAt < cooldownMs;
    };

    if (isCooldownActive()) {
      return;
    }

    let shown = false;

    const reveal = () => {
      if (shown) {
        return;
      }
      shown = true;
      banner.hidden = false;
      setLastShownAt(Date.now());
    };

    const onScroll = () => {
      const scrollableHeight = document.documentElement.scrollHeight - window.innerHeight;
      if (scrollableHeight <= 0) {
        return;
      }
      const ratio = window.scrollY / scrollableHeight;
      if (ratio >= 0.55) {
        reveal();
        window.removeEventListener("scroll", onScroll);
      }
    };

    dismissButton.addEventListener("click", () => {
      banner.hidden = true;
      setLastShownAt(Date.now());
    });

    window.addEventListener("scroll", onScroll, { passive: true });
  })();
</script>

<style>
  .contextual-cta {
    margin-top: 1rem;
    padding: 0.9rem;
    display: grid;
    gap: 0.65rem;
    border-left: 4px solid var(--brand-accent);
    background: #fcf9f2;
  }

  .cta-text p {
    margin: 0;
  }

  .cta-actions {
    display: flex;
    gap: 0.45rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .cta-dismiss {
    border: 0;
    background: transparent;
    color: var(--brand-muted);
    text-decoration: underline;
    cursor: pointer;
    padding: 0.2rem;
    font: inherit;
  }

  @media (max-width: 720px) {
    .cta-actions {
      align-items: stretch;
    }

    .cta-actions .button {
      width: fit-content;
    }
  }
</style>
