---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Fil d'ariane">
  <ol>
    {
      items.map((item, index) => (
        <li>
          {item.href ? <a href={item.href}>{item.label}</a> : <span aria-current="page">{item.label}</span>}
          {index < items.length - 1 && <span class="sep">/</span>}
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .breadcrumbs ol {
    list-style: none;
    margin: 0 0 1.2rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-soft);
    font-size: 0.9rem;
  }

  .breadcrumbs a {
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    text-decoration: underline;
  }

  .sep {
    color: #8b857b;
    margin-left: 0.1rem;
  }
</style>
