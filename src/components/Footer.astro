---
import {
  communityUrl,
  instagramUrl,
  isConfiguredExternalUrl,
  tiktokUrl,
  youtubeUrl
} from "../config/identity";
import { brandMascotSrc, hasBrandMascot } from "../lib/brand";
import { withBase } from "../lib/links";
import { featuredResources, resourcesCatalog } from "../lib/resources";

const year = new Date().getFullYear();

const socialLinks = [
  { label: "YouTube", url: youtubeUrl },
  { label: "Communauté", url: communityUrl },
  { label: "TikTok", url: tiktokUrl },
  { label: "Instagram", url: instagramUrl }
];

const rankedResources = [...resourcesCatalog].sort((a, b) => {
  if (a.wizardScore !== b.wizardScore) {
    return b.wizardScore - a.wizardScore;
  }
  if (a.isFeatured !== b.isFeatured) {
    return a.isFeatured ? -1 : 1;
  }
  return a.name.localeCompare(b.name, "fr");
});

const topTools = [...featuredResources, ...rankedResources.filter((entry) => !featuredResources.some((item) => item.key === entry.key))].slice(0, 8);
---

<footer class="site-footer">
  <div class="container footer-search-bar surface-muted">
    <p class="small muted">Recherche rapide</p>
    <form class="footer-search-form" action={withBase("/recherche/")} method="get">
      <label class="sr-only" for="footer-search-input">Rechercher sur le site</label>
      <input id="footer-search-input" data-footer-search-input type="search" name="q" placeholder="Rechercher un article, guide, vidéo ou outil" />
      <button class="button button-primary" type="submit">Rechercher</button>
    </form>
  </div>

  <div class="container footer-grid">
    <div class="footer-brand">
      <p class="eyebrow">Thésard Au Calme</p>
      <p class="small">Contenus pédagogiques pour doctorant·es en France. Méthode sobre, progression durable, conversion éthique.</p>
      {
        hasBrandMascot && brandMascotSrc && (
          <img class="footer-mascot" src={brandMascotSrc} alt="" width="88" height="88" loading="lazy" decoding="async" aria-hidden="true" />
        )
      }
    </div>

    <div>
      <p class="footer-title">Navigation</p>
      <ul>
        <li><a href={withBase("/start/")}>Commencer</a></li>
        <li><a href={withBase("/articles/")}>Blog</a></li>
        <li><a href={withBase("/guides/")}>Guides</a></li>
        <li><a href={withBase("/videos/")}>Vidéos</a></li>
        <li><a href={withBase("/recherche/")}>Recherche</a></li>
      </ul>
    </div>

    <div>
      <p class="footer-title">Toolbox</p>
      <ul>
        <li><a href={withBase("/outils/")}>Toolbox complète</a></li>
        <li><a href={withBase("/outils/avis/")}>Avis outils</a></li>
        <li><a href={withBase("/stacks/")}>Stacks</a></li>
        <li><a href={withBase("/playlists/")}>Playlists</a></li>
        <li><a href={withBase("/classements/outils-doctorat/")}>Classements</a></li>
        <li><a href={withBase("/ressources/")}>Ressources</a></li>
      </ul>
    </div>

    <div>
      <p class="footer-title">Top outils</p>
      <ul>
        {topTools.map((tool) => <li><a href={withBase(`/outils/${tool.key}/`)}>{tool.name}</a></li>)}
        <li><a href={withBase("/outils/")}>Découvrir la toolbox</a></li>
      </ul>
    </div>

    <div>
      <p class="footer-title">Communauté</p>
      <ul>
        <li><a href={withBase("/communaute/")}>Hub communauté</a></li>
        <li><a href={withBase("/communaute/defis/")}>Défis</a></li>
        <li><a href={withBase("/communaute/kit/")}>Kit de départ</a></li>
        <li><a href={withBase("/downloads/")}>Pack gratuit</a></li>
        <li><a href={withBase("/newsletter/")}>Newsletter</a></li>
      </ul>
    </div>

    <div>
      <p class="footer-title">Réseaux & légal</p>
      <ul>
        {
          socialLinks.map((entry) => (
            <li>
              {
                isConfiguredExternalUrl(entry.url) ? (
                  <a href={entry.url} target="_blank" rel="noopener nofollow">
                    {entry.label}
                  </a>
                ) : (
                  <span class="small muted">{entry.label} (URL à configurer)</span>
                )
              }
            </li>
          ))
        }
        <li><a href={withBase("/legal/affiliation/")}>Affiliation</a></li>
        <li><a href={withBase("/legal/confidentialite/")}>Confidentialité</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p class="small muted">© {year} Thésard Au Calme. Tous droits réservés.</p>
    <p class="small muted">Transparence: certains liens peuvent générer une commission sans surcoût.</p>
  </div>
</footer>

<script is:inline>
  (() => {
    const searchInput = document.querySelector("[data-footer-search-input]");
    if (!(searchInput instanceof HTMLInputElement)) {
      return;
    }

    searchInput.addEventListener("focus", () => {
      if (!window.matchMedia("(min-width: 980px)").matches) {
        return;
      }

      const trigger = document.querySelector("[data-open-search-palette]");
      if (trigger instanceof HTMLElement) {
        trigger.click();
      }
    });
  })();
</script>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    background: linear-gradient(180deg, #f2ece2 0%, #eee9df 100%);
  }

  .footer-search-bar {
    margin-bottom: var(--space-6);
    padding: 0.85rem;
    display: grid;
    gap: 0.45rem;
  }

  .footer-search-bar p {
    margin: 0;
  }

  .footer-search-form {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .footer-search-form input {
    min-width: 250px;
    flex: 1;
    border: 1px solid var(--brand-border);
    border-radius: var(--radius-pill);
    padding: 0.58rem 0.82rem;
    font: inherit;
    background: #fff;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.2fr repeat(5, 1fr);
    gap: 1.25rem;
  }

  .footer-brand {
    display: grid;
    gap: 0.45rem;
  }

  .footer-brand p {
    margin: 0;
  }

  .footer-mascot {
    width: 76px;
    height: 76px;
    border-radius: var(--radius-2);
    border: 1px solid var(--brand-border);
    background: #fff;
  }

  .footer-grid ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.24rem;
  }

  .footer-grid a {
    color: var(--text-soft);
    text-decoration: none;
  }

  .footer-grid a:hover {
    color: var(--brand-accent);
    text-decoration: underline;
  }

  .footer-title {
    margin: 0 0 0.45rem;
    color: var(--text);
    font-weight: 700;
    font-size: 0.94rem;
  }

  .footer-bottom {
    border-top: 1px solid var(--border);
    margin-top: var(--space-5);
    padding: var(--space-4) 0 var(--space-5);
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    border: 0;
    padding: 0;
    clip: rect(0 0 0 0);
    overflow: hidden;
    white-space: nowrap;
  }

  @media (max-width: 1120px) {
    .footer-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-search-form input {
      min-width: 0;
    }
  }
</style>
