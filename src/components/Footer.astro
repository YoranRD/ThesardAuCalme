---
import {
  communityUrl,
  instagramUrl,
  isConfiguredExternalUrl,
  tiktokUrl,
  youtubeUrl
} from "../config/identity";
import { withBase } from "../lib/links";
import { featuredResources, resourcesCatalog } from "../lib/resources";

const year = new Date().getFullYear();

const socialLinks = [
  { label: "YouTube", url: youtubeUrl },
  { label: "Communauté", url: communityUrl },
  { label: "TikTok", url: tiktokUrl },
  { label: "Instagram", url: instagramUrl }
];

const rankedResources = [...resourcesCatalog].sort((a, b) => {
  if (a.wizardScore !== b.wizardScore) {
    return b.wizardScore - a.wizardScore;
  }
  if (a.isFeatured !== b.isFeatured) {
    return a.isFeatured ? -1 : 1;
  }
  return a.name.localeCompare(b.name, "fr");
});

const topTools = [...featuredResources, ...rankedResources.filter((entry) => !featuredResources.some((item) => item.key === entry.key))].slice(0, 8);
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="eyebrow">Thésard Au Calme</p>
      <p class="small">Contenus pédagogiques pour doctorant·es en France. Approche méthodique, transparente et sans promesse irréaliste.</p>
    </div>

    <div>
      <p class="footer-title">Navigation</p>
      <ul>
        <li><a href={withBase("/start/")}>Commencer ici</a></li>
        <li><a href={withBase("/outils/")}>Toolbox outils</a></li>
        <li><a href={withBase("/outils/avis/")}>Avis outils</a></li>
        <li><a href={withBase("/articles/")}>Articles</a></li>
        <li><a href={withBase("/ressources/")}>Ressources</a></li>
      </ul>
    </div>

    <div>
      <p class="footer-title">Outils gratuits</p>
      <ul>
        <li><a href={withBase("/downloads/")}>Téléchargements</a></li>
        <li><a href={withBase("/newsletter/")}>Newsletter</a></li>
        <li><a href={withBase("/communaute/")}>Communauté</a></li>
        <li><a href={withBase("/communaute/kit/")}>Kit première semaine</a></li>
        <li><a href={withBase("/youtube/")}>YouTube</a></li>
      </ul>
    </div>

    <div>
      <p class="footer-title">Top outils</p>
      <ul>
        {topTools.map((tool) => <li><a href={withBase(`/outils/${tool.key}/`)}>{tool.name}</a></li>)}
        <li><a href={withBase("/outils/")}>Découvrir la toolbox</a></li>
      </ul>
    </div>

    <div>
      <p class="footer-title">Chaîne & communauté</p>
      <ul>
        {
          socialLinks.map((entry) => (
            <li>
              {
                isConfiguredExternalUrl(entry.url) ? (
                  <a href={entry.url} target="_blank" rel="noopener nofollow">
                    {entry.label}
                  </a>
                ) : (
                  <span class="small muted">{entry.label} (URL à configurer)</span>
                )
              }
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <p class="footer-title">Cadre légal</p>
      <ul>
        <li><a href={withBase("/legal/")}>Vue d'ensemble légale</a></li>
        <li><a href={withBase("/legal/mentions-legales/")}>Mentions légales</a></li>
        <li><a href={withBase("/legal/confidentialite/")}>Confidentialité</a></li>
        <li><a href={withBase("/legal/affiliation/")}>Affiliation</a></li>
        <li><a href={withBase("/brand/")}>Brand & transparence</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p class="small muted">© {year} Thésard Au Calme. Tous droits réservés.</p>
    <p class="small muted">Transparence: certains liens peuvent générer une commission sans surcoût.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    padding-top: 2.4rem;
    background: #f2eee5;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr 1fr 1fr;
    gap: 1.4rem;
  }

  .footer-grid ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.28rem;
  }

  .footer-grid a {
    color: var(--text-soft);
    text-decoration: none;
  }

  .footer-grid a:hover {
    text-decoration: underline;
  }

  .footer-title {
    margin: 0 0 0.45rem;
    color: var(--text);
    font-weight: 700;
  }

  .footer-bottom {
    border-top: 1px solid var(--border);
    margin-top: 1.5rem;
    padding: 0.85rem 0 1.5rem;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  @media (max-width: 1080px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 700px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
