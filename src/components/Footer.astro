---
import { withBase } from "../lib/links";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="eyebrow">Thésard Au Calme</p>
      <p class="small">Contenus pédagogiques pour doctorant·es en France. Approche méthodique, transparente et sans promesse irréaliste.</p>
    </div>

    <div>
      <p class="footer-title">Navigation</p>
      <ul>
        <li><a href={withBase("/start/")}>Commencer ici</a></li>
        <li><a href={withBase("/videos/")}>Vidéos</a></li>
        <li><a href={withBase("/guides/")}>Guides</a></li>
        <li><a href={withBase("/ressources/")}>Ressources</a></li>
        <li><a href={withBase("/series/")}>Séries</a></li>
        <li><a href={withBase("/recherche/")}>Recherche</a></li>
      </ul>
    </div>

    <div>
      <p class="footer-title">Outils gratuits</p>
      <ul>
        <li><a href={withBase("/downloads/")}>Downloads</a></li>
        <li><a href={withBase("/newsletter/")}>Newsletter</a></li>
        <li><a href={withBase("/templates/")}>Templates</a></li>
        <li><a href={withBase("/faq/")}>FAQ</a></li>
        <li><a href={withBase("/glossaire/")}>Glossaire</a></li>
      </ul>
    </div>

    <div>
      <p class="footer-title">Cadre légal</p>
      <ul>
        <li><a href={withBase("/legal/mentions-legales/")}>Mentions légales</a></li>
        <li><a href={withBase("/legal/confidentialite/")}>Confidentialité</a></li>
        <li><a href={withBase("/legal/affiliation/")}>Affiliation</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p class="small muted">© {year} Thésard Au Calme. Tous droits réservés.</p>
    <p class="small muted">Transparence: certains liens peuvent générer une commission sans surcoût.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    padding-top: 2.4rem;
    background: #f2eee5;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 1.4rem;
  }

  .footer-grid ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.28rem;
  }

  .footer-grid a {
    color: var(--text-soft);
    text-decoration: none;
  }

  .footer-grid a:hover {
    text-decoration: underline;
  }

  .footer-title {
    margin: 0 0 0.45rem;
    color: var(--text);
    font-weight: 700;
  }

  .footer-bottom {
    border-top: 1px solid var(--border);
    margin-top: 1.5rem;
    padding: 0.85rem 0 1.5rem;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  @media (max-width: 980px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 700px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
