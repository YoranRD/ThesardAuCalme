---
import { getCollection } from "astro:content";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import CtaBlock from "../components/CtaBlock.astro";
import TopToolsStrip from "../components/TopToolsStrip.astro";
import { withBase } from "../lib/links";
import { resourceByKey } from "../lib/resources";
import BaseLayout from "../layouts/BaseLayout.astro";

const videos = await getCollection("videos", ({ data }) => data.lang === "fr");
const guides = await getCollection("guides", ({ data }) => data.lang === "fr");

const videosBySlug = new Map(videos.map((video) => [video.slug, video]));
const guidesBySlug = new Map(guides.map((guide) => [guide.slug, guide]));

const requireVideo = (slug: string) => {
  const entry = videosBySlug.get(slug);
  if (!entry) {
    throw new Error(`Missing video for /start profile: ${slug}`);
  }
  return entry;
};

const requireGuide = (slug: string) => {
  const entry = guidesBySlug.get(slug);
  if (!entry) {
    throw new Error(`Missing guide for /start profile: ${slug}`);
  }
  return entry;
};

const requireResource = (key: string) => {
  const entry = resourceByKey.get(key);
  if (!entry) {
    throw new Error(`Missing resource for /start profile: ${key}`);
  }
  return entry;
};

const profiles = [
  {
    title: "Je débute la thèse",
    description:
      "Objectif: construire une base administrative et méthodologique solide pendant les 8 premières semaines.",
    videos: [
      requireVideo("doctorat-france-kit-administratif"),
      requireVideo("top-5-outils-these"),
      requireVideo("top-5-erreurs-these")
    ],
    guides: [
      requireGuide("workflow-bibliographie-zotero"),
      requireGuide("systeme-ecriture-lecture-notes-chapitre")
    ],
    shortlist: [requireResource("campus-france"), requireResource("zotero"), requireResource("syncthing")]
  },
  {
    title: "Je rédige",
    description: "Objectif: maintenir un flux d'écriture stable et réduire les itérations de correction.",
    videos: [
      requireVideo("top-5-outils-these"),
      requireVideo("top-5-erreurs-these"),
      requireVideo("doctorat-france-kit-administratif")
    ],
    guides: [
      requireGuide("systeme-ecriture-lecture-notes-chapitre"),
      requireGuide("workflow-bibliographie-zotero")
    ],
    shortlist: [requireResource("obsidian"), requireResource("antidote"), requireResource("focus-to-do")]
  },
  {
    title: "Je prépare la soutenance",
    description: "Objectif: fiabiliser les preuves, les annexes et les éléments de communication finale.",
    videos: [
      requireVideo("top-5-erreurs-these"),
      requireVideo("doctorat-france-kit-administratif"),
      requireVideo("top-5-outils-these")
    ],
    guides: [
      requireGuide("workflow-bibliographie-zotero"),
      requireGuide("systeme-ecriture-lecture-notes-chapitre")
    ],
    shortlist: [requireResource("backblaze"), requireResource("zotero"), requireResource("google-calendar")]
  }
];
---

<BaseLayout
  canonicalPath="/start/"
  title="Commencer ici | Thésard Au Calme"
  description="Parcours guidé pour doctorants: débuts, rédaction et préparation de soutenance avec vidéos, guides et shortlist ressources."
>
  <section class="section">
    <div class="container">
      <Breadcrumbs items={[{ label: "Accueil", href: "/" }, { label: "Commencer ici" }]} />
      <p class="eyebrow">Onboarding</p>
      <h1>Commencer ici</h1>
      <p class="prose">
        Cette page propose un chemin court selon la phase actuelle du doctorat. Chaque profil rassemble
        3 vidéos, 2 guides et 1 shortlist de ressources pour démarrer sans surcharge.
      </p>
    </div>
  </section>

  <section class="section top-tools-start">
    <div class="container">
      <TopToolsStrip
        title="Top outils pour lancer une routine doctorale"
        description="Sélection courte pour déployer un système de travail simple en moins d'une heure."
        limit={8}
      />
    </div>
  </section>

  <section class="section">
    <div class="container grid">
      {
        profiles.map((profile) => (
          <article class="surface profile-card">
            <h2>{profile.title}</h2>
            <p>{profile.description}</p>

            <h3>3 vidéos recommandées</h3>
            <ul>
              {profile.videos.map((video) => <li><a href={withBase(`/videos/${video.slug}/`)}>{video.data.title}</a></li>)}
            </ul>

            <h3>2 guides à lire</h3>
            <ul>
              {profile.guides.map((guide) => <li><a href={withBase(`/guides/${guide.slug}/`)}>{guide.data.title}</a></li>)}
            </ul>

            <h3>Shortlist ressources</h3>
            <ul>
              {profile.shortlist.map((resource) => <li><a href={withBase(`/ressources/#${resource.key}`)}>{resource.name}</a></li>)}
            </ul>
            <a class="button button-secondary" href={withBase("/ressources/")}>Voir la shortlist dans Ressources</a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="container">
      <CtaBlock
        title="Va voir la page ressources + checklist"
        body="La checklist opérationnelle est en bas de la page Ressources pour démarrer sur un système minimal viable en 30 minutes."
        href={withBase("/ressources/#checklist")}
        label="Ouvrir Ressources + checklist"
      />
    </div>
  </section>

  <section class="section">
    <div class="container surface quick-links">
      <h2>Boîte à outils rapide</h2>
      <p>
        Pour avancer immédiatement: passer par la toolbox, lire les avis, puis enchaîner sur les articles scriptés et le pack
        gratuit.
      </p>
      <div class="quick-actions">
        <a class="button button-secondary" href={withBase("/outils/")}>Toolbox outils</a>
        <a class="button button-secondary" href={withBase("/outils/avis/")}>Avis outils</a>
        <a class="button button-secondary" href={withBase("/articles/")}>Articles</a>
        <a class="button button-secondary" href={withBase("/downloads/")}>Téléchargements</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .profile-card {
    padding: 1.2rem;
    display: grid;
    gap: 0.5rem;
  }

  .top-tools-start {
    padding-top: 0;
  }

  .profile-card ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--text-soft);
  }

  .profile-card a {
    text-decoration: none;
  }

  .profile-card a:hover {
    text-decoration: underline;
  }

  .quick-links {
    padding: 1.2rem;
    display: grid;
    gap: 0.7rem;
  }

  .quick-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
</style>
