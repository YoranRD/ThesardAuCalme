---
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import { shortlistProfiles, type ProfileConfig } from "../../../data/shortlists";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { withBase } from "../../../lib/links";
import { getResourceOutboundPath, resourceByKey, type ResourceEntry } from "../../../lib/resources";

export async function getStaticPaths() {
  return shortlistProfiles.map((profile) => ({
    params: { profile: profile.slug },
    props: { profile }
  }));
}

interface Props {
  profile: ProfileConfig;
}

const { profile } = Astro.props;

const groupedResources = profile.groups.map((group) => {
  const resources: ResourceEntry[] = group.keys.map((key) => {
    const resource = resourceByKey.get(key);
    if (!resource) {
      throw new Error(`Unknown resource key in shortlist ${profile.slug}: ${key}`);
    }
    return resource;
  });

  return {
    objective: group.objective,
    resources
  };
});

const resourceCount = groupedResources.reduce((count, group) => count + group.resources.length, 0);
---

<BaseLayout
  canonicalPath={`/ressources/shortlists/${profile.slug}/`}
  title={`${profile.title} | Shortlist ressources`}
  description={`Shortlist ${profile.title.toLowerCase()} avec outils groupés par objectifs, critères de sélection et exemple de démarrage.`}
>
  <section class="section">
    <div class="container prose">
      <Breadcrumbs
        items={[
          { label: "Accueil", href: "/" },
          { label: "Ressources", href: "/ressources/" },
          { label: "Shortlists", href: "/ressources/shortlists/" },
          { label: profile.title }
        ]}
      />
      <p class="eyebrow">Shortlist profil</p>
      <h1>{profile.title}</h1>
      <p>{profile.criteria}</p>
      <p><strong>Exemple:</strong> {profile.example}</p>
      <p class="small muted">{resourceCount} outils sélectionnés.</p>
    </div>
  </section>

  <section class="section">
    <div class="container grid">
      {
        groupedResources.map((group) => (
          <section class="surface objective-block">
            <h2>{group.objective}</h2>
            <div class="grid card-grid">
              {
                group.resources.map((resource) => (
                  <article class="card resource-card">
                    <h3 id={resource.key}>{resource.name}</h3>
                    <p>{resource.description}</p>
                    <p class="small muted">Tarification: {resource.pricingNote}</p>
                    <a class="button button-secondary" href={getResourceOutboundPath(resource.key)} rel="nofollow sponsored">
                      Ouvrir la ressource
                    </a>
                  </article>
                ))
              }
            </div>
          </section>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="container surface objective-block">
      <h2>Aller plus loin</h2>
      <p>Compléter la shortlist avec les comparaisons détaillées et alternatives gratuites.</p>
      <a class="button button-secondary" href={withBase("/ressources/")}>Retour à la page ressources</a>
    </div>
  </section>
</BaseLayout>

<style>
  .objective-block {
    padding: 1.2rem;
    display: grid;
    gap: 0.9rem;
  }

  .card-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .resource-card {
    display: grid;
    gap: 0.55rem;
  }

  .resource-card h3 {
    margin: 0;
  }

  .resource-card a {
    width: fit-content;
  }

  @media (max-width: 980px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
