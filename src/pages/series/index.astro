---
import { getCollection } from "astro:content";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/links";
import { seriesCatalog } from "../../data/series";

const guides = await getCollection("guides", ({ data }) => data.lang === "fr" && Boolean(data.series));
const videos = await getCollection("videos", ({ data }) => data.lang === "fr" && Boolean(data.series));

const rows = seriesCatalog.map((series) => {
  const guideCount = guides.filter((guide) => guide.data.series === series.key).length;
  const videoCount = videos.filter((video) => video.data.series === series.key).length;

  return {
    ...series,
    guideCount,
    videoCount,
    total: guideCount + videoCount
  };
});
---

<BaseLayout
  canonicalPath="/series/"
  title="Séries | Thésard Au Calme"
  description="Séries éditoriales pour avancer étape par étape: Zotero propre, écriture sans friction et doctorat en France international."
>
  <section class="section">
    <div class="container prose">
      <Breadcrumbs items={[{ label: "Accueil", href: "/" }, { label: "Séries" }]} />
      <p class="eyebrow">Séries</p>
      <h1>Parcours structurés</h1>
      <p>
        Une série regroupe vidéos et guides dans un ordre utile. Le but est de réduire l'hésitation: une étape,
        une action, un livrable.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container grid cards-grid">
      {
        rows.map((row) => (
          <article class="card series-card">
            <h2>{row.title}</h2>
            <p>{row.description}</p>
            <p class="small muted">{row.total} contenus · {row.videoCount} vidéos · {row.guideCount} guides</p>
            <a class="button button-secondary" href={withBase(`/series/${row.slug}/`)}>
              Ouvrir la série
            </a>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .cards-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .series-card {
    display: grid;
    gap: 0.7rem;
  }

  @media (max-width: 980px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
