---
import { getCollection } from "astro:content";
import IconCard from "../components/IconCard.astro";
import Mascot from "../components/Mascot.astro";
import TopToolsStrip from "../components/TopToolsStrip.astro";
import VideoCard from "../components/VideoCard.astro";
import { communityUrl, isConfiguredExternalUrl, youtubeUrl } from "../config/identity";
import { brandDisplayName, brandTagline, getCanonicalUrl } from "../config/site";
import { playlists } from "../data/playlists";
import { getMascotSrc } from "../lib/brand-mascots";
import { withBase } from "../lib/links";
import BaseLayout from "../layouts/BaseLayout.astro";

const videos = (await getCollection("videos", ({ data }) => data.lang === "fr")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const articles = (await getCollection("articles", ({ data }) => data.lang === "fr")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const featuredVideos = videos.slice(0, 3);
const featuredArticles = articles.slice(0, 3);
const featuredPlaylists = playlists.slice(0, 3);
const hasHeroMascot = Boolean(getMascotSrc("default"));

const youtubeCta = isConfiguredExternalUrl(youtubeUrl) ? youtubeUrl : withBase("/youtube/");
const communityCta = isConfiguredExternalUrl(communityUrl) ? communityUrl : withBase("/communaute/rejoindre/");

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      name: brandDisplayName,
      url: getCanonicalUrl("/"),
      logo: getCanonicalUrl("/favicon.svg"),
      description: brandTagline
    },
    {
      "@type": "WebSite",
      name: brandDisplayName,
      url: getCanonicalUrl("/"),
      inLanguage: "fr",
      potentialAction: {
        "@type": "SearchAction",
        target: `${getCanonicalUrl("/")}recherche/?q={search_term_string}`,
        "query-input": "required name=search_term_string"
      }
    }
  ]
};
---

<BaseLayout
  canonicalPath="/"
  title="Thésard Au Calme | Méthodes doctorat en France"
  description="Chaîne no-face et bibliothèque de guides pour réussir son doctorat en France: méthode, outils et rigueur sans bruit marketing."
  jsonLd={structuredData}
>
  <section class="section">
    <div class:list={{ container: true, hero: true, "surface-hero": true, "hero-no-mascot": !hasHeroMascot }}>
      <div class="hero-copy">
        <p class="eyebrow">Doctorat en France</p>
        <h1>Un système calme pour avancer chaque semaine.</h1>
        <p>
          {brandDisplayName} relie vidéos, articles, playlists et outils dans un parcours orienté exécution.
          L’objectif: produire des sorties mesurables sans surcharge cognitive.
        </p>
        <p class="small muted">{brandTagline}</p>
        <div class="hero-actions">
          <a class="button button-primary" href={withBase("/start/")}>Commencer ici</a>
          <a class="button button-secondary" href={withBase("/youtube/")}>Explorer le hub YouTube</a>
          <a class="button button-ghost" href={withBase("/downloads/")}>Pack gratuit</a>
        </div>
      </div>

      {
        hasHeroMascot && (
          <div class="hero-art">
            <Mascot action="default" size="lg" />
            <p class="small muted">Cadence sobre, livrables concrets, transparence totale.</p>
          </div>
        )
      }
    </div>
  </section>

  <section class="section features-section">
    <div class="container grid features-grid">
      <IconCard
        title="Parcours Start"
        description="Priorités semaine 1, checklist et feuille de route doctorale."
        href="/start/"
        icon="→"
        badgeLabel="Démarrer"
        badgeVariant="featured"
      />
      <IconCard
        title="Blog & scripts"
        description="Articles lisibles avec essentiel à retenir, TOC et outils liés."
        href="/articles/"
        icon="✍"
        badgeLabel="Lire"
        badgeVariant="best"
      />
      <IconCard
        title="Communauté"
        description="Hub rejoindre: pack, réseau, chaîne et prochaines actions."
        href="/communaute/rejoindre/"
        icon="◎"
        badgeLabel="Cadence"
        badgeVariant="verified"
      />
      <IconCard
        title="Classements"
        description="Top 5 outils par usage: doctorat, bibliographie, rédaction."
        href="/classements/outils-doctorat/"
        icon="🏆"
        badgeLabel="Top 5"
        badgeVariant="deal"
      />
    </div>
  </section>

  <section class="section top-tools-home">
    <div class="container">
      <TopToolsStrip
        title="Top outils recommandés"
        description="Sélection courte et durable: score éditorial, avis détaillés et sortie directe via /out/."
        limit={8}
      />
    </div>
  </section>

  <section class="section latest-section">
    <div class="container latest-grid">
      <article class="surface latest-block">
        <div class="block-head">
          <p class="eyebrow">Vidéos récentes</p>
          <a class="small" href={withBase("/videos/")}>Tout voir</a>
        </div>
        <div class="grid cards-3">
          {featuredVideos.map((video) => <VideoCard video={video} />)}
        </div>
      </article>

      <article class="surface latest-block">
        <div class="block-head">
          <p class="eyebrow">Articles du moment</p>
          <a class="small" href={withBase("/articles/")}>Tout voir</a>
        </div>
        <div class="grid article-cards">
          {
            featuredArticles.map((article) => (
              <article class="card article-card">
                <p class="small muted">{article.data.date.toLocaleDateString("fr-FR")}</p>
                <h3><a href={withBase(`/articles/${article.slug}/`)}>{article.data.title}</a></h3>
                <p>{article.data.summary}</p>
              </article>
            ))
          }
        </div>
      </article>

      <article class="surface latest-block playlists-block">
        <div class="block-head">
          <p class="eyebrow">Playlists</p>
          <a class="small" href={withBase("/playlists/")}>Toutes les routes</a>
        </div>
        <div class="grid playlist-cards">
          {
            featuredPlaylists.map((playlist) => (
              <article class="card playlist-card">
                <h3><a href={withBase(`/playlists/${playlist.slug}/`)}>{playlist.title}</a></h3>
                <p>{playlist.summary}</p>
                <a class="button button-secondary" href={withBase(`/playlists/${playlist.slug}/`)}>Suivre les étapes</a>
              </article>
            ))
          }
        </div>
      </article>
    </div>
  </section>

  <section class="section community-cta-section">
    <div class="container surface community-cta">
      <h2>Chaîne + communauté + toolbox</h2>
      <p>
        Chaque contenu renvoie vers une action faisable immédiatement. Le hub communauté centralise les prochaines étapes
        et la toolbox garde les recommandations lisibles.
      </p>
      <div class="hero-actions">
        <a class="button button-secondary" href={youtubeCta} target={isConfiguredExternalUrl(youtubeCta) ? "_blank" : undefined} rel={isConfiguredExternalUrl(youtubeCta) ? "noopener nofollow" : undefined}>Chaîne YouTube</a>
        <a class="button button-secondary" href={communityCta} target={isConfiguredExternalUrl(communityCta) ? "_blank" : undefined} rel={isConfiguredExternalUrl(communityCta) ? "noopener nofollow" : undefined}>Rejoindre la communauté</a>
        <a class="button button-secondary" href={withBase("/outils/")}>Ouvrir la toolbox</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.2fr minmax(220px, 320px);
    gap: 1.2rem;
    padding: clamp(1.25rem, 3.2vw, 2.2rem);
    align-items: center;
  }

  .hero-copy {
    display: grid;
    gap: 0.65rem;
  }

  .hero-copy p {
    margin: 0;
    max-width: 78ch;
  }

  .hero-actions {
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
    margin-top: 0.35rem;
  }

  .hero-art {
    border: 1px solid var(--brand-border);
    border-radius: var(--radius-3);
    background: linear-gradient(140deg, #f8fbfd 0%, #e9f2f6 100%);
    padding: 0.8rem;
    display: grid;
    gap: 0.5rem;
    justify-items: center;
  }

  .hero-art p {
    margin: 0;
    text-align: center;
  }

  .hero.hero-no-mascot {
    grid-template-columns: 1fr;
  }

  .features-section,
  .top-tools-home,
  .latest-section,
  .community-cta-section {
    padding-top: 0;
  }

  .features-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .latest-grid {
    display: grid;
    gap: 0.9rem;
  }

  .latest-block {
    padding: 1rem;
    display: grid;
    gap: 0.7rem;
  }

  .block-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .block-head p {
    margin: 0;
  }

  .cards-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .article-cards,
  .playlist-cards {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .article-card,
  .playlist-card {
    display: grid;
    gap: 0.45rem;
  }

  .article-card p,
  .playlist-card p,
  .article-card h3,
  .playlist-card h3 {
    margin: 0;
  }

  .article-card a,
  .playlist-card a {
    text-decoration: none;
  }

  .article-card a:hover,
  .playlist-card a:hover {
    text-decoration: underline;
  }

  .community-cta {
    padding: 1.2rem;
    display: grid;
    gap: 0.55rem;
  }

  .community-cta p,
  .community-cta h2 {
    margin: 0;
  }

  @media (max-width: 1080px) {
    .hero,
    .cards-3,
    .article-cards,
    .playlist-cards {
      grid-template-columns: 1fr;
    }

    .features-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
