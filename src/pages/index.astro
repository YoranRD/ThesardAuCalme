---
import { getCollection } from "astro:content";
import mascot from "../assets/brand/mascot.svg";
import CtaBlock from "../components/CtaBlock.astro";
import GuideCard from "../components/GuideCard.astro";
import VideoCard from "../components/VideoCard.astro";
import { communityUrl, isConfiguredExternalUrl, youtubeUrl } from "../config/identity";
import { brandDisplayName, brandTagline, getCanonicalUrl } from "../config/site";
import { withBase } from "../lib/links";
import { resourcesCatalog } from "../lib/resources";
import BaseLayout from "../layouts/BaseLayout.astro";

const videos = (await getCollection("videos", ({ data }) => data.lang === "fr")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const guides = (await getCollection("guides", ({ data }) => data.lang === "fr")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const articles = (await getCollection("articles", ({ data }) => data.lang === "fr")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const featuredVideos = videos.slice(0, 3);
const featuredGuides = guides.slice(0, 2);
const featuredArticles = articles.slice(0, 3);
const featuredResources = resourcesCatalog.slice(0, 4);

const youtubeCta = isConfiguredExternalUrl(youtubeUrl) ? youtubeUrl : withBase("/contact/");
const communityCta = isConfiguredExternalUrl(communityUrl) ? communityUrl : withBase("/contact/");

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      name: brandDisplayName,
      url: getCanonicalUrl("/"),
      logo: getCanonicalUrl("/favicon.svg"),
      description: brandTagline
    },
    {
      "@type": "WebSite",
      name: brandDisplayName,
      url: getCanonicalUrl("/"),
      inLanguage: "fr",
      potentialAction: {
        "@type": "SearchAction",
        target: `${getCanonicalUrl("/")}guides/?q={search_term_string}`,
        "query-input": "required name=search_term_string"
      }
    }
  ]
};
---

<BaseLayout
  canonicalPath="/"
  title="Thésard Au Calme | Méthodes doctorat en France"
  description="Chaîne no-face et bibliothèque de guides pour réussir son doctorat en France: méthode, outils et rigueur sans bruit marketing."
  jsonLd={structuredData}
>
  <section class="section">
    <div class="container hero surface">
      <div>
        <p class="eyebrow">Doctorat en France</p>
        <h1>Un cadre clair pour terminer sa thèse avec plus de calme.</h1>
        <p>
          {brandDisplayName} publie des vidéos et des guides orientés exécution: organisation hebdomadaire,
          rédaction, bibliographie et préparation de soutenance.
        </p>
        <p>{brandTagline}</p>
        <div class="hero-actions">
          <a class="button button-primary" href={withBase("/start/")}>Commencer ici</a>
          <a class="button button-secondary" href={withBase("/videos/")}>Voir les vidéos</a>
        </div>
      </div>
      <div class="hero-art">
        <img src={mascot.src} alt="Mascotte Thésard Au Calme" width="220" height="220" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Vidéos récentes</p>
      <div class="grid cards-3">
        {featuredVideos.map((video) => <VideoCard video={video} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Guides approfondis</p>
      <div class="grid cards-2">
        {featuredGuides.map((guide) => <GuideCard guide={guide} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container surface article-preview">
      <p class="eyebrow">Articles vidéo-ready</p>
      <h2>Script d'abord, vidéo ensuite</h2>
      <p>
        Les nouveaux articles servent de base script pour les prochaines vidéos. Chaque publication contient des checklists
        et des exemples directement réutilisables.
      </p>
      <div class="grid cards-3">
        {
          featuredArticles.map((article) => (
            <article class="card article-card">
              <p class="small muted">{article.data.status === "published" ? "Publié" : "Coming soon"}</p>
              <h3><a href={withBase(`/articles/${article.slug}/`)}>{article.data.title}</a></h3>
              <p>{article.data.summary}</p>
            </article>
          ))
        }
      </div>
      <a class="button button-secondary" href={withBase("/articles/")}>Voir tous les articles</a>
    </div>
  </section>

  <section class="section">
    <div class="container resources-preview surface">
      <div>
        <p class="eyebrow">Ressources sélectionnées</p>
        <h2>Des recommandations expliquées, pas des liens jetés.</h2>
      </div>
      <ul>
        {featuredResources.map((resource) => <li><a href={withBase(`/ressources/#${resource.key}`)}>{resource.name}</a></li>)}
      </ul>
      <a class="button button-secondary" href={withBase("/ressources/")}>Explorer toutes les ressources</a>
    </div>
  </section>

  <section class="section">
    <div class="container surface community-cta">
      <h2>Chaîne + communauté</h2>
      <p>
        Pour garder la cadence: contenus YouTube no-face, défis hebdo et retours d\'exécution en communauté.
      </p>
      <div class="hero-actions">
        <a class="button button-secondary" href={youtubeCta} target={isConfiguredExternalUrl(youtubeCta) ? "_blank" : undefined} rel={isConfiguredExternalUrl(youtubeCta) ? "noopener nofollow" : undefined}>Chaîne YouTube</a>
        <a class="button button-secondary" href={communityCta} target={isConfiguredExternalUrl(communityCta) ? "_blank" : undefined} rel={isConfiguredExternalUrl(communityCta) ? "noopener nofollow" : undefined}>Rejoindre la communauté</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container disclosure">
      <strong>Note affiliation:</strong>
      Certains liens de la page ressources passent par des redirections internes `/out/` pour mesurer les clics.
      Le critère prioritaire reste l'utilité académique, avec alternatives gratuites quand elles existent.
    </div>
  </section>

  <section class="section">
    <div class="container">
      <CtaBlock
        title="Démarrage guidé"
        body="La page Commencer ici propose trois parcours rapides: début de thèse, phase de rédaction, préparation de soutenance."
        href={withBase("/start/")}
        label="Ouvrir Commencer ici"
      />
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.35fr minmax(180px, 280px);
    gap: 1.2rem;
    padding: clamp(1.2rem, 3vw, 2rem);
    align-items: center;
  }

  .hero-actions {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: 1.15rem;
  }

  .hero-art {
    justify-self: center;
    width: min(100%, 260px);
  }

  .cards-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .cards-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .resources-preview {
    display: grid;
    gap: 0.7rem;
    padding: 1.4rem;
  }

  .article-preview {
    display: grid;
    gap: 0.7rem;
    padding: 1.4rem;
  }

  .article-card {
    display: grid;
    gap: 0.45rem;
  }

  .article-card h3 {
    margin: 0;
  }

  .article-card a {
    text-decoration: none;
  }

  .community-cta {
    padding: 1.2rem;
    display: grid;
    gap: 0.55rem;
  }

  .resources-preview ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--text-soft);
    columns: 2;
  }

  .resources-preview a {
    text-decoration: none;
  }

  .resources-preview a:hover,
  .article-card a:hover {
    text-decoration: underline;
  }

  @media (max-width: 980px) {
    .cards-3,
    .cards-2 {
      grid-template-columns: 1fr;
    }

    .hero {
      grid-template-columns: 1fr;
    }
  }
</style>
