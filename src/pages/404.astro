---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/links";
---

<BaseLayout
  canonicalPath="/404/"
  title="Page introuvable | Thésard Au Calme"
  description="La page demandée est introuvable. Reprendre depuis la page de départ, la recherche ou les articles."
  noindex={true}
>
  <section class="section">
    <div class="container surface not-found">
      <p class="eyebrow">Erreur 404</p>
      <h1>Cette page n'existe pas</h1>
      <p>Le lien est peut-être expiré ou mal saisi. Revenir vers un point d'entrée fiable.</p>
      <div class="actions">
        <a class="button button-primary" href={withBase("/start/")}>Start</a>
        <a class="button button-secondary" href={withBase("/recherche/")}>Search</a>
        <a class="button button-secondary" href={withBase("/articles/")}>Articles</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    max-width: 62ch;
    padding: clamp(1.3rem, 3vw, 2rem);
    display: grid;
    gap: 0.75rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
</style>
