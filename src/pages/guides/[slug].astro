---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import TagList from "../../components/TagList.astro";
import { brandDisplayName } from "../../config/site";
import { seriesByKey } from "../../data/series";
import { getRelatedVideosForGuide, getSeriesItems, getSeriesNeighbors } from "../../lib/content-relations";
import { withBase } from "../../lib/links";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const guides = await getCollection("guides");
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide }
  }));
}

interface Props {
  guide: CollectionEntry<"guides">;
}

const { guide } = Astro.props;
const { Content, headings } = await render(guide);

const isFrench = guide.data.lang === "fr";
const pageLang = isFrench ? "fr" : "en";
const locale = isFrench ? "fr-FR" : "en-US";

const publicationDate = guide.data.date.toLocaleDateString(locale, {
  day: "2-digit",
  month: "long",
  year: "numeric"
});

const allVideos = await getCollection("videos", ({ data }) => data.lang === guide.data.lang);
const allGuides = await getCollection("guides", ({ data }) => data.lang === guide.data.lang);

const relatedVideos = getRelatedVideosForGuide(
  guide,
  allVideos.filter((video) => video.slug !== guide.slug),
  3
);

const seriesItems = guide.data.series
  ? getSeriesItems(allGuides, allVideos, guide.data.series, guide.data.lang)
  : [];

const seriesNeighbors = getSeriesNeighbors(seriesItems, "guide", guide.slug);
const seriesDefinition = guide.data.series ? seriesByKey.get(guide.data.series) : undefined;
---

<BaseLayout
  canonicalPath={`/guides/${guide.slug}/`}
  title={`${guide.data.title} | ${brandDisplayName}`}
  description={guide.data.summary}
  type="article"
  lang={pageLang}
>
  <section class="section">
    <div class="container">
      <Breadcrumbs
        items={[
          { label: isFrench ? "Accueil" : "Home", href: isFrench ? "/" : "/en/" },
          { label: isFrench ? "Guides" : "Guides", href: "/guides/" },
          { label: guide.data.title }
        ]}
      />
      <p class="eyebrow">{isFrench ? "Guide" : "Guide"}</p>
      <h1>{guide.data.title}</h1>
      <p class="small muted">{isFrench ? "Publié le" : "Published on"} {publicationDate}</p>
      <p class="prose">{guide.data.summary}</p>
      <TagList tags={guide.data.tags} />
    </div>
  </section>

  {
    headings.length > 0 && (
      <section class="section toc-section">
        <div class="container toc-wrap">
          <TableOfContents headings={headings} title={isFrench ? "Sommaire du guide" : "Guide outline"} />
        </div>
      </section>
    )
  }

  <section class="section">
    <article class="container surface guide-body prose">
      <Content />
    </article>
  </section>

  {
    relatedVideos.length > 0 && (
      <section class="section">
        <div class="container surface guide-body">
          <h2>{isFrench ? "Vidéos liées" : "Related videos"}</h2>
          <div class="grid related-grid">
            {
              relatedVideos.map((video) => (
                <article class="card related-card">
                  <p class="small muted">{isFrench ? "Vidéo" : "Video"} · {video.data.durationMin} min</p>
                  <h3><a href={withBase(`/videos/${video.slug}/`)}>{video.data.title}</a></h3>
                  <p>{video.data.summary}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>
    )
  }

  {
    guide.data.series && (
      <section class="section">
        <div class="container surface guide-body">
          <h2>{isFrench ? "Navigation de série" : "Series navigation"}</h2>
          <p class="small muted">
            {seriesDefinition ? seriesDefinition.title : guide.data.series}
            {seriesDefinition && isFrench && ` · `}
            {
              seriesDefinition && isFrench && (
                <a href={withBase(`/series/${seriesDefinition.slug}/`)}>Voir toute la série</a>
              )
            }
          </p>
          <div class="series-nav">
            {
              seriesNeighbors.previous ? (
                <a class="button button-secondary" href={withBase(seriesNeighbors.previous.path)}>
                  ← {isFrench ? "Précédent" : "Previous"}: {seriesNeighbors.previous.title}
                </a>
              ) : (
                <span class="small muted">{isFrench ? "Début de série" : "Series start"}</span>
              )
            }
            {
              seriesNeighbors.next ? (
                <a class="button button-secondary" href={withBase(seriesNeighbors.next.path)}>
                  {isFrench ? "Suivant" : "Next"}: {seriesNeighbors.next.title} →
                </a>
              ) : (
                <span class="small muted">{isFrench ? "Fin de série" : "Series end"}</span>
              )
            }
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .guide-body {
    padding: clamp(1.2rem, 3vw, 2.1rem);
  }

  .toc-section {
    padding-top: 0;
  }

  .toc-wrap {
    max-width: 75ch;
  }

  .related-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
    margin-top: 0.8rem;
  }

  .related-card {
    display: grid;
    gap: 0.55rem;
  }

  .related-card h3 {
    margin: 0;
  }

  .related-card a {
    text-decoration: none;
  }

  .series-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
    margin-top: 0.6rem;
  }

  @media (max-width: 980px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
