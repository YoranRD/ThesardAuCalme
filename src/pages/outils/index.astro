---
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { withBase } from "../../lib/links";
import { getResourcesByObjective } from "../../lib/resources";
import BaseLayout from "../../layouts/BaseLayout.astro";

const objectives = getResourcesByObjective().filter((section) => section.items.length > 0);
---

<BaseLayout
  canonicalPath="/outils/"
  title="Outils doctorat | Fiches logiciels"
  description="Catalogue logiciel doctorat orienté objectifs: écrire, citer, lire, sauvegarder, focus et administratif, avec fiches outils détaillées."
>
  <section class="section">
    <div class="container prose">
      <Breadcrumbs items={[{ label: "Accueil", href: "/" }, { label: "Outils" }]} />
      <p class="eyebrow">Outils logiciels</p>
      <h1>Fiches outils par objectif</h1>
      <p>
        Cette section sert de couche pratique: pour chaque outil, une fiche claire avec bénéfices, pièges, checklist de setup
        et alternatives gratuites.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container surface top-note">
      <h2>Transparence</h2>
      <p>
        Les boutons "Ouvrir l'outil" passent par `/out/[key]/` pour mesurer les clics sortants. Aucun changement de prix,
        aucune priorité vendue: l'ordre dépend de l'utilité réelle dans un workflow doctoral.
      </p>
      <a class="button button-secondary" href={withBase("/legal/affiliation/")}>Voir la politique d'affiliation</a>
    </div>
  </section>

  <section class="section">
    <div class="container grid objective-grid">
      {
        objectives.map((section) => (
          <section class="surface objective-block" id={section.objective.key}>
            <p class="eyebrow">Objectif</p>
            <h2>{section.objective.label}</h2>
            <p>{section.objective.description}</p>
            <div class="grid card-grid">
              {
                section.items.map((resource) => (
                  <article class="card tool-card">
                    <p class="small muted">{resource.pricingNote}</p>
                    <h3><a href={withBase(`/outils/${resource.key}/`)}>{resource.name}</a></h3>
                    <p>{resource.description}</p>
                    <div class="actions">
                      <a class="button button-secondary" href={withBase(`/outils/${resource.key}/`)}>Voir la fiche</a>
                      <a class="button button-secondary" href={withBase(`/out/${resource.key}/`)} rel="nofollow sponsored">Ouvrir l'outil</a>
                    </div>
                  </article>
                ))
              }
            </div>
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .top-note {
    padding: 1.2rem;
    display: grid;
    gap: 0.65rem;
  }

  .objective-grid {
    gap: 1.6rem;
  }

  .objective-block {
    padding: 1.2rem;
    display: grid;
    gap: 0.75rem;
  }

  .card-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .tool-card {
    display: grid;
    gap: 0.45rem;
  }

  .tool-card h3 {
    margin: 0;
  }

  .tool-card a {
    text-decoration: none;
  }

  .tool-card a:hover {
    text-decoration: underline;
  }

  .actions {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  @media (max-width: 980px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
