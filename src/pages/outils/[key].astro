---
import { getCollection } from "astro:content";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { withBase } from "../../lib/links";
import {
  getResourceObjectiveKey,
  getResourceOutboundPath,
  resourceByKey,
  resourceObjectives,
  resourcesCatalog,
  type ResourceEntry
} from "../../lib/resources";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  return resourcesCatalog.map((resource) => ({
    params: { key: resource.key },
    props: { resource }
  }));
}

interface Props {
  resource: ResourceEntry;
}

const { resource } = Astro.props;

const toolReviews = await getCollection("toolReviews", ({ data }) => data.lang === "fr");
const reviewByResourceKey = new Map(toolReviews.map((review) => [review.data.resourceKey, review]));
const reviewEntry = reviewByResourceKey.get(resource.key);
const reviewPath = reviewEntry ? withBase(`/outils/avis/${reviewEntry.slug}/`) : null;

const objectiveKey = getResourceObjectiveKey(resource);
const objective = resourceObjectives.find((entry) => entry.key === objectiveKey);

const whoItsForByObjective: Record<string, string> = {
  ecrire: "Doctorant-es qui veulent passer d'un brouillon disperse a un systeme d'ecriture tenable.",
  "citer-bibliographie": "Doctorant-es qui doivent fiabiliser citations, bibliographies et tracabilite des sources.",
  "lire-pdf-annoter": "Doctorant-es qui lisent beaucoup de PDF et veulent reinjecter les notes dans la redaction.",
  "sauvegarder-synchroniser": "Doctorant-es qui veulent reduire le risque de perte de donnees et garder des versions restaurables.",
  "focus-routine": "Doctorant-es qui cherchent une routine hebdo stable avec moins de dispersion quotidienne.",
  administratif: "Doctorant-es en France, notamment internationaux, qui doivent sequencer les demarches administratives."
};

const setupChecklistByObjective: Record<string, string[]> = {
  ecrire: [
    "Creer un dossier projet unique et une convention de noms.",
    "Definir un flux note vers paragraphe comme sortie standard.",
    "Preparer un template de section reutilisable.",
    "Planifier 3 sessions d'ecriture hebdomadaires.",
    "Tester l'export du projet vers format neutre.",
    "Faire une revue de structure chaque fin de semaine."
  ],
  "citer-bibliographie": [
    "Choisir un style de citation unique par projet.",
    "Importer 20 references test et corriger les metadonnees.",
    "Creer 5 tags thematiques coherents.",
    "Verifier le flux insertion citation dans l'editeur principal.",
    "Nettoyer doublons et champs vides chaque semaine.",
    "Exporter une bibliographie de test avant redaction intensive."
  ],
  "lire-pdf-annoter": [
    "Definir 3 types d'annotations (resultat, limite, idee).",
    "Creer un template de note de lecture en 10 lignes.",
    "Programmer 2 sessions lecture + synthese hebdomadaires.",
    "Tester l'export des highlights vers outil de notes.",
    "Relier chaque lecture a une section de chapitre cible.",
    "Archiver les PDF dans une arborescence stable."
  ],
  "sauvegarder-synchroniser": [
    "Identifier les dossiers critiques de these.",
    "Mettre en place 3 copies selon la regle 3-2-1.",
    "Configurer une sauvegarde automatique quotidienne.",
    "Creer un point de restauration hebdomadaire.",
    "Tester la recuperation d'un dossier complet.",
    "Documenter la procedure de restauration en 1 page."
  ],
  "focus-routine": [
    "Definir 3 priorites hebdo maximum.",
    "Planifier des blocs focus de 60 a 90 minutes.",
    "Regrouper l'administratif sur des creneaux dedies.",
    "Fixer une revue hebdo de 20 minutes.",
    "Supprimer les taches sans livrable explicite.",
    "Mesurer la progression par sorties, pas par heures."
  ],
  administratif: [
    "Lister toutes les demarches actives avec dates limites.",
    "Associer chaque dossier a une source officielle.",
    "Creer un dossier de preuves (PDF + captures).",
    "Definir l'ordre d'execution des demarches critiques.",
    "Programmer un controle hebdo des echeances.",
    "Preparer un email type pour demandes de clarification."
  ]
};

const pitfallsByObjective: Record<string, string[]> = {
  ecrire: [
    "Multiplier les outils d'ecriture sans convention de fichiers.",
    "Changer de methode chaque semaine au lieu de stabiliser une routine.",
    "Negliger l'export des donnees avant des refontes de structure."
  ],
  "citer-bibliographie": [
    "Importer des references sans controle des metadonnees.",
    "Melanger styles de citation dans un meme manuscrit.",
    "Ignorer les doublons jusqu'a la phase de soumission."
  ],
  "lire-pdf-annoter": [
    "Surligner sans creer de synthese reutilisable.",
    "Conserver les annotations dans un format difficile a exporter.",
    "Lire sans objectif de sortie (note, paragraphe, section)."
  ],
  "sauvegarder-synchroniser": [
    "Confondre synchronisation et sauvegarde de version.",
    "Ne pas tester la restauration d'un fichier critique.",
    "Centraliser toutes les copies sur un seul fournisseur."
  ],
  "focus-routine": [
    "Utiliser une todo illimitee sans priorisation journaliere.",
    "Empiler les minuteries sans revue hebdomadaire.",
    "Planifier des journees irrealistes sans marge d'imprevu."
  ],
  administratif: [
    "Suivre des conseils de forum sans verifier les sources officielles.",
    "Traiter les dossiers dans le mauvais ordre.",
    "Perdre les preuves administratives faute d'archivage centralise."
  ]
};

const alternatives = resource.freeAlternativeKeys
  .map((key) => resourceByKey.get(key))
  .filter((entry): entry is ResourceEntry => Boolean(entry))
  .slice(0, 2);

if (alternatives.length < 2) {
  const fallback = resourcesCatalog
    .filter((entry) => entry.key !== resource.key && getResourceObjectiveKey(entry) === objectiveKey)
    .slice(0, 2 - alternatives.length);
  alternatives.push(...fallback);
}

const scoreFill = `${Math.max(0, Math.min(100, (resource.wizardScore / 5) * 100))}%`;
const formattedScore = resource.wizardScore.toFixed(1).replace(/\.0$/, "");

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: resource.name,
  description: resource.description,
  applicationCategory: objective?.label ?? "Doctorat",
  operatingSystem: "Web",
  offers: {
    "@type": "Offer",
    priceCategory: resource.priceTier
  },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: resource.wizardScore,
    bestRating: 5,
    worstRating: 1
  }
};
---

<BaseLayout
  canonicalPath={`/outils/${resource.key}/`}
  title={`${resource.name} | Fiche outil doctorat`}
  description={`${resource.name}: fiche premium avec score, cas d'usage, alternatives et CTA vers l'outil.`}
  jsonLd={softwareJsonLd}
>
  <section class="section">
    <div class="container summary-hero">
      <Breadcrumbs
        items={[
          { label: "Accueil", href: "/" },
          { label: "Outils", href: "/outils/" },
          { label: resource.name }
        ]}
      />
      <article class="surface summary-card">
        <p class="eyebrow">Fiche outil</p>
        <h1>{resource.name}</h1>
        <p>{resource.description}</p>
        <p class="small muted">{resource.badge ?? "Selection editoriale"}</p>

        <div class="summary-meta">
          <span class="star-meter" aria-label={`Score ${formattedScore} sur 5`}>
            <span class="star-back">★★★★★</span>
            <span class="star-front" style={`width:${scoreFill}`}>★★★★★</span>
          </span>
          <span class="small">{formattedScore}/5</span>
          <span class="meta-pill">{resource.priceTier}</span>
          <span class="meta-pill">{objective?.label ?? "Support doctorat"}</span>
        </div>

        <ul class="meta-list bestfor-chips">
          {resource.bestFor.map((entry) => <li class="meta-pill">{entry}</li>)}
        </ul>

        <div class="actions">
          <a class="button button-primary" href={getResourceOutboundPath(resource.key)} rel="nofollow sponsored">Decouvrir l'outil</a>
          {
            reviewPath ? (
              <a class="button button-secondary" href={reviewPath}>Lire l'avis detaille</a>
            ) : (
              <a class="button button-secondary" href={withBase(`/outils/avis/`)}>Voir les avis</a>
            )
          }
        </div>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container grid two-cols">
      <article class="surface block">
        <h2>Pour qui</h2>
        <p>{whoItsForByObjective[objectiveKey] ?? "Doctorant-es qui veulent un systeme plus stable et verifiable."}</p>

        <h2>Pourquoi recommande</h2>
        <ul>
          {resource.whyRecommended.map((item) => <li>{item}</li>)}
        </ul>

        <h2>Criteres utilises</h2>
        <ul>
          {resource.criteriaUsed.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="surface block">
        <h2>Setup en 10 minutes</h2>
        <ol>
          {(setupChecklistByObjective[objectiveKey] ?? []).map((item) => <li>{item}</li>)}
        </ol>

        <h2>Pieges frequents</h2>
        <ul>
          {(pitfallsByObjective[objectiveKey] ?? []).map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container surface compare-block">
      <h2>Compare alternatives</h2>
      <p class="small muted">
        Deux options proches pour arbitrer selon contexte, budget et niveau de maturite du workflow.
      </p>
      <div class="grid alternatives-grid">
        {
          alternatives.map((entry) => (
            <article class="card alternative-card">
              <h3>{entry.name}</h3>
              <p class="small muted">Score: {entry.wizardScore.toFixed(1).replace(/\.0$/, "")}/5 · {entry.priceTier}</p>
              <ul>
                <li><strong>Choisir {entry.name} pour:</strong> {entry.bestFor.slice(0, 2).join(" · ")}</li>
                <li><strong>Choisir {resource.name} pour:</strong> {resource.bestFor.slice(0, 2).join(" · ")}</li>
                {entry.avoidIf.length > 0 && <li><strong>A eviter si:</strong> {entry.avoidIf.join(" · ")}</li>}
              </ul>
              <div class="actions">
                <a class="button button-secondary" href={withBase(`/outils/${entry.key}/`)}>Voir la fiche</a>
                <a class="button button-secondary" href={getResourceOutboundPath(entry.key)} rel="nofollow sponsored">Ouvrir</a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container surface disclosure-box">
      <h2>Transparence</h2>
      <p>
        Les sorties externes utilisent <code>/out/[key]/</code> pour mesurer les clics. Aucun changement de prix et aucune
        priorite vendue. Les criteres editoriaux restent explicites et revisables.
      </p>
      <a class="button button-secondary" href={withBase("/legal/affiliation/")}>Politique d'affiliation</a>
    </div>
  </section>
</BaseLayout>

<style>
  .summary-hero {
    display: grid;
    gap: 0.9rem;
  }

  .summary-card {
    padding: 1.2rem;
    display: grid;
    gap: 0.7rem;
  }

  .summary-meta {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .star-meter {
    position: relative;
    display: inline-flex;
    line-height: 1;
    font-size: 1rem;
  }

  .star-back {
    color: #cfc8bc;
    letter-spacing: 0.02em;
  }

  .star-front {
    position: absolute;
    left: 0;
    top: 0;
    overflow: hidden;
    white-space: nowrap;
    color: #f2b400;
    letter-spacing: 0.02em;
  }

  .bestfor-chips {
    margin: 0;
  }

  .two-cols {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .block {
    padding: 1.2rem;
    display: grid;
    gap: 0.7rem;
  }

  .block ul,
  .block ol {
    margin: 0;
    padding-left: 1.15rem;
    color: var(--text-soft);
  }

  .compare-block {
    padding: 1.2rem;
    display: grid;
    gap: 0.75rem;
  }

  .alternatives-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .alternative-card {
    display: grid;
    gap: 0.55rem;
  }

  .alternative-card ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--text-soft);
  }

  .actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .disclosure-box {
    padding: 1.2rem;
    background: #faf5ee;
    border: 1px solid #e0c39c;
    display: grid;
    gap: 0.6rem;
  }

  @media (max-width: 980px) {
    .two-cols,
    .alternatives-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
