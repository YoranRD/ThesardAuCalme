---
import { getCollection } from "astro:content";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ToolboxMiniNav from "../../components/ToolboxMiniNav.astro";
import { withBase } from "../../lib/links";
import {
  getResourceObjectiveKey,
  getResourceOutboundPath,
  resourceByKey,
  resourceObjectives,
  resourcesCatalog,
  type ResourceEntry
} from "../../lib/resources";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  return resourcesCatalog.map((resource) => ({
    params: { key: resource.key },
    props: { resource }
  }));
}

interface Props {
  resource: ResourceEntry;
}

const { resource } = Astro.props;

const toolReviews = await getCollection("toolReviews", ({ data }) => data.lang === "fr");
const reviewByResourceKey = new Map(toolReviews.map((review) => [review.data.resourceKey, review]));
const reviewEntry = reviewByResourceKey.get(resource.key);
const reviewPath = reviewEntry ? withBase(`/outils/avis/${reviewEntry.slug}/`) : null;

const objectiveKey = getResourceObjectiveKey(resource);
const objective = resourceObjectives.find((entry) => entry.key === objectiveKey);

const whoItsForByObjective: Record<string, string> = {
  ecrire: "Doctorant·es qui doivent transformer des notes brutes en sections prêtes à relire.",
  "citer-bibliographie": "Doctorant·es qui veulent éviter les erreurs de citations et fiabiliser les sources.",
  "lire-pdf-annoter": "Doctorant·es avec un volume élevé de PDF à analyser et réinjecter en rédaction.",
  "sauvegarder-synchroniser": "Doctorant·es qui veulent sécuriser les fichiers de thèse sur plusieurs supports.",
  "focus-routine": "Doctorant·es qui cherchent un rythme de travail tenable sans surcharge mentale.",
  administratif: "Doctorant·es en France, notamment internationaux, qui doivent enchaîner des démarches sensibles."
};

const whereToStartByObjective: Record<string, string[]> = {
  ecrire: [
    "Créer un espace de projet unique avec une convention de noms.",
    "Préparer un template de section pour limiter les frictions de démarrage.",
    "Planifier trois sessions courtes d'écriture cette semaine.",
    "Mesurer la progression en pages utilisables, pas en heures passées."
  ],
  "citer-bibliographie": [
    "Importer un lot test de 20 références et corriger les métadonnées.",
    "Fixer un style de citation unique pour tout le manuscrit.",
    "Activer une routine hebdo anti-doublons.",
    "Tester un export bibliographique avant phase de soumission."
  ],
  "lire-pdf-annoter": [
    "Définir une grille d'annotation simple (résultat, limite, citation).",
    "Relier chaque annotation à une note de synthèse exploitable.",
    "Planifier deux sessions lecture + synthèse par semaine.",
    "Vérifier l'export des annotations vers le système d'écriture."
  ],
  "sauvegarder-synchroniser": [
    "Lister les dossiers critiques de la thèse.",
    "Déployer une règle 3-2-1 avec au moins une copie hors machine principale.",
    "Automatiser la sauvegarde quotidienne.",
    "Tester une restauration complète de dossier."
  ],
  "focus-routine": [
    "Définir trois priorités hebdo maximum.",
    "Bloquer des sessions focus de 60 à 90 minutes.",
    "Créer une revue hebdomadaire de 20 minutes.",
    "Supprimer les tâches sans livrable clair."
  ],
  administratif: [
    "Lister les démarches actives et leurs dates limites.",
    "Associer chaque démarche à une source officielle.",
    "Centraliser les preuves (PDF, récépissés, captures).",
    "Mettre en place une revue administrative hebdomadaire."
  ]
};

const proofOfUseByObjective: Record<string, string[]> = {
  ecrire: [
    "Structurer un chapitre en sous-sections prêtes à relire en fin de semaine.",
    "Passer d'un corpus de notes à une version 0.1 partageable avec l'encadrement.",
    "Maintenir un flux d'écriture stable pendant les périodes administratives intenses."
  ],
  "citer-bibliographie": [
    "Fiabiliser les références avant soumission d'article ou de chapitre.",
    "Réduire les corrections tardives liées au format de citations.",
    "Conserver la traçabilité des sources entre lecture et rédaction."
  ],
  "lire-pdf-annoter": [
    "Transformer les highlights en arguments directement réutilisables.",
    "Accélérer la revue de littérature avec une grille homogène.",
    "Réduire le temps de reprise après interruption de lecture."
  ],
  "sauvegarder-synchroniser": [
    "Protéger un manuscrit en cours contre panne matérielle.",
    "Restaurer rapidement une version propre après erreur de manipulation.",
    "Garder une copie exploitable en cas de perte de machine principale."
  ],
  "focus-routine": [
    "Limiter la dispersion quotidienne via des blocs focus cadrés.",
    "Protéger la rédaction pendant les semaines à charge variable.",
    "Installer des routines courtes pour conserver un rythme durable."
  ],
  administratif: [
    "Séquencer les démarches de séjour sans collision d'échéances.",
    "Conserver des preuves prêtes en cas de relance institutionnelle.",
    "Réduire le coût mental des démarches répétitives."
  ]
};

const pitfallsByObjective: Record<string, string[]> = {
  ecrire: [
    "Multiplier les outils d'écriture sans protocole de passage.",
    "Confondre activité et sortie réellement utilisable.",
    "Refondre l'organisation toutes les semaines sans stabilisation."
  ],
  "citer-bibliographie": [
    "Importer des références sans contrôle de métadonnées.",
    "Mélanger plusieurs styles de citation dans un même document.",
    "Reporter le nettoyage biblio à la phase finale."
  ],
  "lire-pdf-annoter": [
    "Surligner sans produire de synthèse.",
    "Lire sans objectif de sortie (note, paragraphe, section).",
    "Laisser les annotations dans des formats difficilement exportables."
  ],
  "sauvegarder-synchroniser": [
    "Confondre synchronisation et sauvegarde versionnée.",
    "Ne jamais tester la restauration.",
    "Concentrer toutes les copies chez un seul fournisseur."
  ],
  "focus-routine": [
    "Planifier des semaines irréalistes.",
    "Accumuler des tâches sans hiérarchisation.",
    "Ignorer les revues hebdomadaires de pilotage."
  ],
  administratif: [
    "Suivre des conseils non officiels sans vérification.",
    "Gérer les démarches dans un ordre inadéquat.",
    "Perdre les preuves faute d'archivage centralisé."
  ]
};

const alternatives = resource.freeAlternativeKeys
  .map((key) => resourceByKey.get(key))
  .filter((entry): entry is ResourceEntry => Boolean(entry))
  .slice(0, 2);

if (alternatives.length < 2) {
  const fallback = resourcesCatalog
    .filter((entry) => entry.key !== resource.key && getResourceObjectiveKey(entry) === objectiveKey)
    .slice(0, 2 - alternatives.length);
  alternatives.push(...fallback);
}

const scoreFill = `${Math.max(0, Math.min(100, (resource.wizardScore / 5) * 100))}%`;
const formattedScore = resource.wizardScore.toFixed(1).replace(/\.0$/, "");

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: resource.name,
  description: resource.description,
  applicationCategory: objective?.label ?? "Doctorat",
  operatingSystem: "Web",
  offers: {
    "@type": "Offer",
    priceCategory: resource.priceTier
  },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: resource.wizardScore,
    bestRating: 5,
    worstRating: 1
  }
};
---

<BaseLayout
  canonicalPath={`/outils/${resource.key}/`}
  title={`${resource.name} | Fiche outil doctorat`}
  description={`${resource.name}: fiche premium avec score, cas d'usage, alternatives et CTA vers l'outil.`}
  jsonLd={softwareJsonLd}
>
  <section class="section">
    <div class="container summary-hero">
      <Breadcrumbs
        items={[
          { label: "Accueil", href: "/" },
          { label: "Outils", href: "/outils/" },
          { label: resource.name }
        ]}
      />

      <article class="surface summary-strip">
        <span class="logo-placeholder" aria-hidden="true">{resource.name.slice(0, 2).toUpperCase()}</span>
        <div class="summary-main">
          <p class="eyebrow">Fiche outil</p>
          <h1>{resource.name}</h1>
          <p>{resource.description}</p>
          <div class="summary-meta">
            <span class="star-meter" aria-label={`Score ${formattedScore} sur 5`}>
              <span class="star-back">★★★★★</span>
              <span class="star-front" style={`width:${scoreFill}`}>★★★★★</span>
            </span>
            <span class="small">{formattedScore}/5</span>
            <span class="meta-pill">{resource.priceTier}</span>
            <span class="meta-pill">{objective?.label ?? "Support doctorat"}</span>
            <span class="meta-pill">{resource.badge ?? "Sélection éditoriale"}</span>
          </div>
          <ul class="meta-list bestfor-chips">
            {resource.bestFor.map((entry) => <li class="meta-pill">{entry}</li>)}
          </ul>
          <div class="actions">
            <a class="button button-primary" href={getResourceOutboundPath(resource.key)} rel="nofollow sponsored">Découvrir l'outil</a>
            {
              reviewPath ? (
                <a class="button button-secondary" href={reviewPath}>Lire l'avis détaillé</a>
              ) : (
                <a class="button button-secondary" href={withBase(`/outils/avis/`)}>Voir les avis</a>
              )
            }
          </div>
        </div>
      </article>

      <ToolboxMiniNav currentKey={resource.key} title="Mini-nav toolbox" />
    </div>
  </section>

  <section class="section">
    <div class="container grid two-cols">
      <article class="surface block">
        <h2>Pour qui</h2>
        <p>{whoItsForByObjective[objectiveKey] ?? "Doctorant·es qui veulent un système plus stable et vérifiable."}</p>

        <h2>Pourquoi recommandé</h2>
        <ul>
          {resource.whyRecommended.map((item) => <li>{item}</li>)}
        </ul>

        <h2>Critères utilisés</h2>
        <ul>
          {resource.criteriaUsed.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="surface block">
        <h2>Où commencer</h2>
        <ol>
          {(whereToStartByObjective[objectiveKey] ?? []).map((item) => <li>{item}</li>)}
        </ol>

        <h2>Pièges fréquents</h2>
        <ul>
          {(pitfallsByObjective[objectiveKey] ?? []).map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container surface proof-block">
      <h2>Preuves d’usage</h2>
      <p class="small muted">Cas concrets de mise en pratique, sans promesse irréaliste.</p>
      <ul>
        {(proofOfUseByObjective[objectiveKey] ?? []).slice(0, 4).map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container surface compare-block">
      <h2>Comparer des alternatives</h2>
      <p class="small muted">
        Deux options proches pour arbitrer selon contexte, budget et maturité du workflow.
      </p>
      <div class="grid alternatives-grid">
        {
          alternatives.map((entry) => (
            <article class="card alternative-card">
              <h3>{entry.name}</h3>
              <p class="small muted">Score: {entry.wizardScore.toFixed(1).replace(/\.0$/, "")}/5 · {entry.priceTier}</p>
              <ul>
                <li><strong>Choisir {entry.name} pour:</strong> {entry.bestFor.slice(0, 2).join(" · ")}</li>
                <li><strong>Choisir {resource.name} pour:</strong> {resource.bestFor.slice(0, 2).join(" · ")}</li>
                {entry.avoidIf.length > 0 && <li><strong>À éviter si:</strong> {entry.avoidIf.join(" · ")}</li>}
              </ul>
              <div class="actions">
                <a class="button button-secondary" href={withBase(`/outils/${entry.key}/`)}>Voir la fiche</a>
                <a class="button button-secondary" href={getResourceOutboundPath(entry.key)} rel="nofollow sponsored">Découvrir</a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container surface disclosure-box">
      <h2>Transparence</h2>
      <p>
        Les sorties externes utilisent <code>/out/[key]/</code> pour mesurer les clics. Aucun changement de prix et aucune priorité vendue.
      </p>
      <a class="button button-secondary" href={withBase("/legal/affiliation/")}>Politique d'affiliation</a>
    </div>
  </section>
</BaseLayout>

<style>
  .summary-hero {
    display: grid;
    gap: 0.9rem;
  }

  .summary-strip {
    padding: 1rem;
    display: grid;
    gap: 0.9rem;
    grid-template-columns: 72px minmax(0, 1fr);
  }

  .logo-placeholder {
    width: 4rem;
    height: 4rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    background: #fff;
    color: var(--accent);
    font-size: 1rem;
  }

  .summary-main {
    display: grid;
    gap: 0.55rem;
    min-width: 0;
  }

  .summary-main h1 {
    margin: 0;
  }

  .summary-meta {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .star-meter {
    position: relative;
    display: inline-flex;
    line-height: 1;
    font-size: 1rem;
  }

  .star-back {
    color: #cfc8bc;
    letter-spacing: 0.02em;
  }

  .star-front {
    position: absolute;
    left: 0;
    top: 0;
    overflow: hidden;
    white-space: nowrap;
    color: #f2b400;
    letter-spacing: 0.02em;
  }

  .bestfor-chips {
    margin: 0;
  }

  .two-cols {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .block {
    padding: 1.2rem;
    display: grid;
    gap: 0.7rem;
  }

  .block ul,
  .block ol,
  .proof-block ul {
    margin: 0;
    padding-left: 1.15rem;
    color: var(--text-soft);
  }

  .proof-block,
  .compare-block {
    padding: 1.2rem;
    display: grid;
    gap: 0.75rem;
  }

  .alternatives-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .alternative-card {
    display: grid;
    gap: 0.55rem;
  }

  .alternative-card ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--text-soft);
  }

  .actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .disclosure-box {
    padding: 1.2rem;
    background: #faf5ee;
    border: 1px solid #e0c39c;
    display: grid;
    gap: 0.6rem;
  }

  @media (max-width: 980px) {
    .summary-strip,
    .two-cols,
    .alternatives-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
