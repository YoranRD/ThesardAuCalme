---
import Breadcrumbs from "../components/Breadcrumbs.astro";
import ResourceCard from "../components/ResourceCard.astro";
import { withBase } from "../lib/links";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getResourcesByObjective, resourcesCatalog } from "../lib/resources";

const objectives = getResourcesByObjective().filter((section) => section.items.length > 0);

const objectiveShortlist = [
  {
    label: "Ecrire",
    href: withBase("/ressources/#ecrire"),
    recommendation: "Obsidian + LanguageTool"
  },
  {
    label: "Citer & bibliographie",
    href: withBase("/ressources/#citer-bibliographie"),
    recommendation: "Zotero + convention de tags"
  },
  {
    label: "Sauvegarder & synchroniser",
    href: withBase("/ressources/#sauvegarder-synchroniser"),
    recommendation: "Syncthing + snapshot hebdo"
  }
];

const comparisonRows = resourcesCatalog
  .filter((resource) => ["zotero", "obsidian", "syncthing", "todoist", "campus-france", "hypothesis"].includes(resource.key))
  .map((resource) => ({
    name: resource.name,
    category: resource.category,
    pricing: resource.pricingNote,
    criteria: resource.criteriaUsed.slice(0, 2).join(" · ")
  }));
---

<BaseLayout
  canonicalPath="/ressources/"
  title="Ressources logiciel doctorat | Thésard Au Calme"
  description="Ressources software pour doctorat: structurées par objectifs, critères explicites, alternatives gratuites et transparence des liens sortants."
>
  <section class="section">
    <div class="container">
      <Breadcrumbs items={[{ label: "Accueil", href: "/" }, { label: "Ressources" }]} />
      <p class="eyebrow">Ressources software</p>
      <h1>Ressources par objectifs</h1>
      <p class="prose">
        Cette page n'est pas un classement d'outils. Chaque recommandation est reliée à un objectif concret de doctorat,
        avec critères explicites, points de vigilance et alternatives gratuites quand elles existent.
      </p>
      <div class="disclosure small">
        <strong>Transparence :</strong>
        les liens externes sortent via des pages internes `/out/[key]/` pour mesurer les clics. Cela ne change pas le prix
        affiché côté service. La priorité reste l'utilité réelle pour un workflow doctoral.
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container surface shortlist">
      <h2>Shortlist 30 minutes</h2>
      <p>
        Objectif: installer un système minimal viable en une seule session. Démarrer avec trois blocs, puis affiner.
      </p>
      <ul>
        {objectiveShortlist.map((item) => <li><a href={item.href}>{item.label}</a> — {item.recommendation}</li>)}
      </ul>
      <a class="button button-secondary" href={withBase("/ressources/#checklist")}>Ouvrir la checklist opérationnelle</a>
      <div class="quick-links">
        <a class="button button-secondary" href={withBase("/ressources/shortlists/")}>Shortlists par profil</a>
        <a class="button button-secondary" href={withBase("/downloads/")}>Téléchargements gratuits</a>
        <a class="button button-secondary" href={withBase("/newsletter/")}>Newsletter (coming soon)</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container table-wrapper">
      <h2>Comparaison rapide</h2>
      <table>
        <thead>
          <tr>
            <th>Ressource</th>
            <th>Famille</th>
            <th>Tarification</th>
            <th>Critères dominants</th>
          </tr>
        </thead>
        <tbody>
          {
            comparisonRows.map((row) => (
              <tr>
                <td>{row.name}</td>
                <td>{row.category}</td>
                <td>{row.pricing}</td>
                <td>{row.criteria}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section class="section">
    <div class="container objective-nav">
      {objectives.map((section) => <a class="meta-pill" href={withBase(`/ressources/#${section.objective.key}`)}>{section.objective.label}</a>)}
    </div>
  </section>

  <section class="section">
    <div class="container grid objectives-grid">
      {
        objectives.map((section) => (
          <section class="objective-block" id={section.objective.key}>
            <p class="eyebrow">Objectif</p>
            <h2>{section.objective.label}</h2>
            <p>{section.objective.description}</p>
            <div class="grid">
              {section.items.map((resource) => <ResourceCard resource={resource} />)}
            </div>
          </section>
        ))
      }
    </div>
  </section>

  <section class="section" id="checklist">
    <div class="container surface checklist">
      <h2>Checklist minimale (30 minutes)</h2>
      <ol>
        <li>Créer un espace d'écriture unique et décider d'une convention de noms de fichiers.</li>
        <li>Importer 20 références dans le gestionnaire bibliographique avec tags homogènes.</li>
        <li>Installer une méthode de sauvegarde 3-2-1 avec au moins un support hors machine.</li>
        <li>Planifier 3 blocs de focus de 90 minutes dans l'agenda de la semaine.</li>
        <li>Vérifier les échéances administratives du mois sur sources officielles.</li>
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .shortlist {
    padding: 1.2rem;
    display: grid;
    gap: 0.7rem;
  }

  .shortlist ul {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--text-soft);
  }

  .shortlist a {
    text-decoration: none;
  }

  .shortlist a:hover {
    text-decoration: underline;
  }

  .quick-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .objective-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .objective-nav a {
    text-decoration: none;
  }

  .objectives-grid {
    gap: 2rem;
  }

  .objective-block {
    display: grid;
    gap: 0.7rem;
  }

  .checklist {
    padding: 1.25rem;
  }

  .checklist ol {
    margin: 0;
    padding-left: 1.25rem;
    color: var(--text-soft);
  }
</style>
