---
import { getCollection } from "astro:content";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import { withBase } from "../../../lib/links";
import { filterGuidesByTagSlug, filterVideosByTagSlug, resolveTagNameFromSlug, slugifyTag } from "../../../lib/tags";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const videos = await getCollection("videos", ({ data }) => data.lang === "en");
  const guides = await getCollection("guides", ({ data }) => data.lang === "en");

  const tags = new Set<string>([
    ...videos.flatMap((video) => video.data.tags.map(slugifyTag)),
    ...guides.flatMap((guide) => guide.data.tags.map(slugifyTag))
  ]);

  return [...tags]
    .filter(Boolean)
    .map((tag) => ({
      params: { tag },
      props: { tagSlug: tag }
    }));
}

interface Props {
  tagSlug: string;
}

const { tagSlug } = Astro.props;

const videos = (await getCollection("videos", ({ data }) => data.lang === "en")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const guides = (await getCollection("guides", ({ data }) => data.lang === "en")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const filteredVideos = filterVideosByTagSlug(videos, tagSlug);
const filteredGuides = filterGuidesByTagSlug(guides, tagSlug);
const displayTag = resolveTagNameFromSlug(tagSlug, videos, guides);
const hasResults = filteredVideos.length > 0 || filteredGuides.length > 0;
---

<BaseLayout
  canonicalPath={`/en/topics/${tagSlug}/`}
  title={`Topic ${displayTag} | Thésard Au Calme`}
  description={`English videos and guides related to ${displayTag} for international PhD workflows in France.`}
  lang="en"
>
  <section class="section">
    <div class="container prose">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/en/" },
          { label: "Topics", href: "/en/topics/" },
          { label: displayTag }
        ]}
      />
      <p class="eyebrow">Topic</p>
      <h1>{displayTag}</h1>
      <p>Cross-listed videos and guides for this tag, sorted by publication date.</p>
    </div>
  </section>

  {
    hasResults ? (
      <>
        <section class="section">
          <div class="container">
            <h2>Videos</h2>
            <div class="grid cards-3">
              {
                filteredVideos.map((video) => (
                  <article class="card simple-card">
                    <p class="small muted">{video.data.date.toLocaleDateString("en-US")}</p>
                    <h3><a href={withBase(`/videos/${video.slug}/`)}>{video.data.title}</a></h3>
                    <p>{video.data.summary}</p>
                  </article>
                ))
              }
            </div>
          </div>
        </section>

        <section class="section">
          <div class="container">
            <h2>Guides</h2>
            <div class="grid cards-2">
              {
                filteredGuides.map((guide) => (
                  <article class="card simple-card">
                    <p class="small muted">{guide.data.date.toLocaleDateString("en-US")}</p>
                    <h3><a href={withBase(`/guides/${guide.slug}/`)}>{guide.data.title}</a></h3>
                    <p>{guide.data.summary}</p>
                  </article>
                ))
              }
            </div>
          </div>
        </section>
      </>
    ) : (
      <section class="section">
        <div class="container surface empty-state">
          <p>No content available yet for this topic.</p>
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .cards-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .cards-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .simple-card {
    display: grid;
    gap: 0.6rem;
  }

  .simple-card a {
    text-decoration: none;
  }

  .empty-state {
    padding: 1.2rem;
  }

  @media (max-width: 980px) {
    .cards-3,
    .cards-2 {
      grid-template-columns: 1fr;
    }
  }
</style>
