---
import { withBase } from "../../lib/links";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  canonicalPath="/en/"
  title="Thesard Au Calme | English"
  description="English section for international doctoral workflows in France, with focused hubs for onboarding, writing, bibliography and practical checklists."
  lang="en"
>
  <section class="section">
    <div class="container prose">
      <p class="eyebrow">English</p>
      <h1>International doctoral workflow in France</h1>
      <p>
        French remains the primary language on the site. The English section focuses on practical onboarding,
        execution systems and high-priority pages for international PhD candidates in France.
      </p>
      <ul>
        <li><a href={withBase("/en/doctorate-in-france/")}>Doctorate in France hub</a></li>
        <li><a href={withBase("/en/international/arrival/")}>Arrival guide</a></li>
        <li><a href={withBase("/en/international/housing/")}>Housing guide</a></li>
        <li><a href={withBase("/en/international/health/")}>Health guide</a></li>
        <li><a href={withBase("/en/international/banking/")}>Banking guide</a></li>
        <li><a href={withBase("/en/search/")}>Search</a></li>
        <li><a href={withBase("/en/faq/")}>FAQ</a></li>
        <li><a href={withBase("/en/glossary/")}>Glossary</a></li>
        <li><a href={withBase("/en/downloads/")}>Downloads</a></li>
      </ul>
      <p>
        French onboarding: <a href={withBase("/start/")}>Commencer ici</a>.
      </p>
    </div>
  </section>
</BaseLayout>
