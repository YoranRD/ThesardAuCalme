---
import { withBase } from "../../lib/links";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  canonicalPath="/en/"
  title="Thesard Au Calme | English"
  description="English section for international doctoral workflows in France, with focused hubs for onboarding, writing and bibliography."
  lang="en"
>
  <section class="section">
    <div class="container prose">
      <p class="eyebrow">English</p>
      <h1>International doctoral workflow in France</h1>
      <p>
        French is the primary publication language. This English section covers practical onboarding and execution content,
        especially for international PhD candidates.
      </p>
      <ul>
        <li><a href={withBase("/en/doctorate-in-france/")}>Doctorate in France hub</a></li>
        <li><a href={withBase("/en/writing/")}>Writing hub</a></li>
        <li><a href={withBase("/en/bibliography/")}>Bibliography hub</a></li>
        <li><a href={withBase("/en/topics/")}>Topics index</a></li>
      </ul>
      <p>
        French onboarding: <a href={withBase("/start/")}>Commencer ici</a>.
      </p>
    </div>
  </section>
</BaseLayout>
