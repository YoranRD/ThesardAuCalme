---
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { withBase } from "../../../lib/links";

const searchIndexUrl = withBase("/search-index.json");
const baseUrl = withBase("/");
---

<BaseLayout
  canonicalPath="/en/search/"
  title="Search | Thésard Au Calme"
  description="Quick search across guides and video pages for international doctoral workflows in France."
  lang="en"
>
  <section class="section">
    <div class="container prose">
      <Breadcrumbs items={[{ label: "Home", href: "/en/" }, { label: "Search" }]} />
      <p class="eyebrow">Search</p>
      <h1>Find the right page in seconds</h1>
      <p>
        This lightweight search runs entirely on a static JSON index and covers all guide and video pages.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container surface search-block">
      <label for="search-input-en">Search by keyword, tag or topic</label>
      <input id="search-input-en" name="q" type="search" placeholder="example: enrollment, zotero, writing" />
      <p id="search-status-en" class="small muted">Loading search index…</p>
      <div id="search-results-en" class="grid results-grid"></div>
    </div>
  </section>

  <section class="section">
    <div class="container surface tips-block">
      <h2>Fast navigation</h2>
      <ul>
        <li><a href={withBase("/en/topics/")}>Browse by topic</a> for focused weekly priorities.</li>
        <li><a href={withBase("/series/")}>Use series pages</a> for step-by-step progression.</li>
        <li><a href={withBase("/ressources/")}>Check resources</a> for software stack decisions.</li>
      </ul>
    </div>
  </section>

  <script is:inline define:vars={{ searchIndexUrl, baseUrl }}>
    const searchInput = document.getElementById("search-input-en");
    const searchStatus = document.getElementById("search-status-en");
    const searchResults = document.getElementById("search-results-en");

    const normalizedBase = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;

    const toBasePath = (path) => {
      if (/^https?:\/\//i.test(path)) {
        return path;
      }
      return `${normalizedBase}${String(path).replace(/^\/+/, "")}`;
    };

    const normalize = (value) =>
      value
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .toLowerCase()
        .trim();

    const formatDate = (isoDate) =>
      new Date(isoDate).toLocaleDateString("en-US", {
        day: "2-digit",
        month: "long",
        year: "numeric"
      });

    const buildCard = (entry) => {
      const article = document.createElement("article");
      article.className = "card result-card";

      const typeLabel = entry.type === "guide" ? "Guide" : "Video";
      const tags = entry.tags.map((tag) => `#${tag}`).join(" · ");

      article.innerHTML = `
        <p class="small muted">${typeLabel} · ${formatDate(entry.date)}</p>
        <h3><a href="${toBasePath(entry.path)}">${entry.title}</a></h3>
        <p>${entry.summary}</p>
        <p class="small muted">${tags}</p>
      `;

      return article;
    };

    const renderResults = (entries, query) => {
      searchResults.innerHTML = "";

      if (!query) {
        searchStatus.textContent = "Type at least 2 characters to start searching.";
        return;
      }

      if (entries.length === 0) {
        searchStatus.textContent = "No results yet. Try broader keywords or tags.";
        return;
      }

      searchStatus.textContent = `${entries.length} result(s).`;
      entries.forEach((entry) => searchResults.appendChild(buildCard(entry)));
    };

    let index = [];

    const applySearch = () => {
      const query = normalize(searchInput.value);
      if (query.length < 2) {
        renderResults([], "");
        return;
      }

      const terms = query.split(/\s+/).filter(Boolean);

      const matches = index.filter((entry) => {
        const haystack = normalize(`${entry.title} ${entry.summary} ${entry.tags.join(" ")}`);
        return terms.every((term) => haystack.includes(term));
      });

      renderResults(matches.slice(0, 30), query);
    };

    fetch(searchIndexUrl)
      .then((response) => {
        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }
        return response.json();
      })
      .then((entries) => {
        index = entries.filter((entry) => entry.lang === "en");
        searchStatus.textContent = "Type at least 2 characters to start searching.";
      })
      .catch(() => {
        searchStatus.textContent = "Search index could not be loaded.";
      });

    searchInput.addEventListener("input", applySearch);
  </script>
</BaseLayout>

<style>
  .search-block {
    padding: 1.2rem;
    display: grid;
    gap: 0.75rem;
  }

  .search-block input {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.72rem 0.8rem;
    font: inherit;
    background: #fff;
  }

  .results-grid {
    margin-top: 0.6rem;
  }

  .result-card {
    display: grid;
    gap: 0.45rem;
  }

  .result-card h3 {
    margin: 0;
  }

  .result-card a {
    text-decoration: none;
  }

  .tips-block {
    padding: 1.2rem;
  }

  .tips-block ul {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--text-soft);
  }

  .tips-block a {
    text-decoration: none;
  }

  .tips-block a:hover {
    text-decoration: underline;
  }
</style>
