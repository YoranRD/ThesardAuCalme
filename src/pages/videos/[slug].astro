---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import TagList from "../../components/TagList.astro";
import { brandDisplayName } from "../../config/site";
import { seriesByKey } from "../../data/series";
import { getRelatedGuidesForVideo, getSeriesItems, getSeriesNeighbors } from "../../lib/content-relations";
import { withBase } from "../../lib/links";
import { getResourceOutboundPath, resourceByKey } from "../../lib/resources";
import { parseChapterTimeToSeconds } from "../../lib/videos";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const videos = await getCollection("videos");
  return videos.map((video) => ({
    params: { slug: video.slug },
    props: { video }
  }));
}

interface Props {
  video: CollectionEntry<"videos">;
}

const { video } = Astro.props;
const { Content } = await render(video);

const isFrench = video.data.lang === "fr";
const pageLang = isFrench ? "fr" : "en";
const locale = isFrench ? "fr-FR" : "en-US";

const publicationDateIso = video.data.date.toISOString();
const publicationDateDisplay = video.data.date.toLocaleDateString(locale, {
  day: "2-digit",
  month: "long",
  year: "numeric"
});

const chapterWithSeconds = video.data.chapters.map((chapter) => ({
  ...chapter,
  seconds: parseChapterTimeToSeconds(chapter.time)
}));

const featuredResources = video.data.featuredResourceKeys.map((key) => {
  const resource = resourceByKey.get(key);
  if (!resource) {
    throw new Error(`Unknown featuredResourceKey in video ${video.slug}: ${key}`);
  }
  return resource;
});

const allGuides = await getCollection("guides", ({ data }) => data.lang === video.data.lang);
const allVideos = await getCollection("videos", ({ data }) => data.lang === video.data.lang);

const relatedGuides = getRelatedGuidesForVideo(
  video,
  allGuides.filter((guide) => guide.slug !== video.slug),
  3
);

const seriesItems = video.data.series
  ? getSeriesItems(allGuides, allVideos, video.data.series, video.data.lang)
  : [];

const seriesNeighbors = getSeriesNeighbors(seriesItems, "video", video.slug);
const seriesDefinition = video.data.series ? seriesByKey.get(video.data.series) : undefined;

const videoStructuredData = {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  name: video.data.title,
  description: video.data.summary,
  uploadDate: publicationDateIso,
  duration: `PT${Math.round(video.data.durationMin)}M`,
  thumbnailUrl: `https://i.ytimg.com/vi/${video.data.youtubeId}/maxresdefault.jpg`,
  embedUrl: `https://www.youtube-nocookie.com/embed/${video.data.youtubeId}`,
  contentUrl: `https://www.youtube.com/watch?v=${video.data.youtubeId}`,
  inLanguage: video.data.lang,
  publisher: {
    "@type": "Organization",
    name: brandDisplayName
  }
};
---

<BaseLayout
  canonicalPath={`/videos/${video.slug}/`}
  title={`${video.data.title} | ${brandDisplayName}`}
  description={video.data.summary}
  type="article"
  image={`https://i.ytimg.com/vi/${video.data.youtubeId}/maxresdefault.jpg`}
  jsonLd={videoStructuredData}
  lang={pageLang}
>
  <section class="section">
    <div class="container">
      <Breadcrumbs
        items={[
          { label: isFrench ? "Accueil" : "Home", href: isFrench ? "/" : "/en/" },
          { label: isFrench ? "Vidéos" : "Videos", href: "/videos/" },
          { label: video.data.title }
        ]}
      />
      <p class="eyebrow">{isFrench ? "Fiche vidéo" : "Video page"}</p>
      <h1>{video.data.title}</h1>
      <p class="small muted">
        {isFrench ? "Publié le" : "Published on"} {publicationDateDisplay} · {video.data.durationMin} min
      </p>
      <p class="prose">{video.data.summary}</p>
      <TagList tags={video.data.tags} />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="video-frame surface">
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${video.data.youtubeId}`}
          title={video.data.title}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid two-columns">
      <article class="surface block prose">
        <h2>{isFrench ? "Résumé détaillé" : "Detailed summary"}</h2>
        <Content />
      </article>

      <aside class="surface block">
        <h2>{isFrench ? "Chapitres" : "Chapters"}</h2>
        <ol class="chapters">
          {
            chapterWithSeconds.map((chapter) => (
              <li>
                <a href={`https://www.youtube.com/watch?v=${video.data.youtubeId}&t=${chapter.seconds}s`} rel="nofollow noopener">
                  <span>{chapter.time}</span>
                  <span>{chapter.label}</span>
                </a>
              </li>
            ))
          }
        </ol>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container grid two-columns">
      <article class="surface block">
        <h2>{isFrench ? "Ressources mises en avant" : "Featured resources"}</h2>
        <ul class="resource-list">
          {
            featuredResources.map((resource) => (
              <li>
                <p><strong>{resource.name}</strong> · {resource.pricingNote}</p>
                <ul>
                  {resource.whyRecommended.map((reason) => <li>{reason}</li>)}
                </ul>
                <a
                  class="button button-secondary"
                  href={getResourceOutboundPath(resource.key)}
                  rel="nofollow sponsored"
                >
                  {isFrench ? "Ouvrir la ressource" : "Open resource"}
                </a>
              </li>
            ))
          }
        </ul>
      </article>

      <article class="surface block">
        <h2>FAQ</h2>
        <div class="faq-grid">
          {
            video.data.faq.map((item) => (
              <details>
                <summary>{item.q}</summary>
                <p>{item.a}</p>
              </details>
            ))
          }
        </div>
      </article>
    </div>
  </section>

  {
    relatedGuides.length > 0 && (
      <section class="section">
        <div class="container surface block">
          <h2>{isFrench ? "Guides liés" : "Related guides"}</h2>
          <div class="grid related-grid">
            {
              relatedGuides.map((guide) => (
                <article class="card related-card">
                  <p class="small muted">{isFrench ? "Guide" : "Guide"}</p>
                  <h3><a href={withBase(`/guides/${guide.slug}/`)}>{guide.data.title}</a></h3>
                  <p>{guide.data.summary}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>
    )
  }

  {
    video.data.series && (
      <section class="section">
        <div class="container surface block">
          <h2>{isFrench ? "Navigation de série" : "Series navigation"}</h2>
          <p class="small muted">
            {seriesDefinition ? seriesDefinition.title : video.data.series}
            {seriesDefinition && isFrench && ` · `}
            {
              seriesDefinition && isFrench && (
                <a href={withBase(`/series/${seriesDefinition.slug}/`)}>Voir toute la série</a>
              )
            }
          </p>
          <div class="series-nav">
            {
              seriesNeighbors.previous ? (
                <a class="button button-secondary" href={withBase(seriesNeighbors.previous.path)}>
                  ← {isFrench ? "Précédent" : "Previous"}: {seriesNeighbors.previous.title}
                </a>
              ) : (
                <span class="small muted">{isFrench ? "Début de série" : "Series start"}</span>
              )
            }
            {
              seriesNeighbors.next ? (
                <a class="button button-secondary" href={withBase(seriesNeighbors.next.path)}>
                  {isFrench ? "Suivant" : "Next"}: {seriesNeighbors.next.title} →
                </a>
              ) : (
                <span class="small muted">{isFrench ? "Fin de série" : "Series end"}</span>
              )
            }
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .video-frame {
    padding: 0.4rem;
  }

  .video-frame iframe {
    width: 100%;
    min-height: clamp(220px, 45vw, 560px);
    border: 0;
    border-radius: 10px;
  }

  .two-columns {
    grid-template-columns: 1.3fr 1fr;
  }

  .block {
    padding: 1.2rem;
  }

  .chapters {
    margin: 0;
    padding-left: 1.1rem;
  }

  .chapters a {
    display: grid;
    grid-template-columns: 58px 1fr;
    gap: 0.45rem;
    color: var(--text-soft);
    text-decoration: none;
  }

  .chapters a:hover {
    color: var(--accent);
  }

  .resource-list {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.7rem;
  }

  .resource-list ul {
    margin: 0.3rem 0 0.65rem;
    color: var(--text-soft);
  }

  .faq-grid {
    display: grid;
    gap: 0.55rem;
  }

  .faq-grid details {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.75rem;
    background: #fff;
  }

  .faq-grid summary {
    cursor: pointer;
    font-weight: 600;
  }

  .related-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .related-card {
    display: grid;
    gap: 0.55rem;
  }

  .related-card h3 {
    margin: 0;
  }

  .related-card a {
    text-decoration: none;
  }

  .series-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
  }

  @media (max-width: 980px) {
    .two-columns,
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
