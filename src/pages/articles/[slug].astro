---
import { getCollection, render, type CollectionEntry } from "astro:content";
import AuthorCard from "../../components/AuthorCard.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CalloutBox from "../../components/CalloutBox.astro";
import ContextualCtaBanner from "../../components/ContextualCtaBanner.astro";
import ContentEnhancements from "../../components/ContentEnhancements.astro";
import Mascot from "../../components/Mascot.astro";
import RelatedTools from "../../components/RelatedTools.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import TagList from "../../components/TagList.astro";
import TopToolsStrip from "../../components/TopToolsStrip.astro";
import { getArticleCategory, getArticleKeyTakeaways, getRelatedToolsForArticle } from "../../lib/article-meta";
import { brandDisplayName } from "../../config/site";
import {
  isConfiguredExternalUrl,
  youtubeUrl
} from "../../config/identity";
import {
  getRelatedArticles,
  getRelatedGuidesForArticle,
  getRelatedVideosForArticle
} from "../../lib/content-relations";
import { withBase } from "../../lib/links";
import { estimateReadingTimeMinutes } from "../../lib/reading-time";
import {
  getResourceOutboundPath,
  getResourceReviewPath,
  resourcesCatalog
} from "../../lib/resources";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

interface Props {
  article: CollectionEntry<"articles">;
}

const { article } = Astro.props;
const { Content, headings } = await render(article);

const isFrench = article.data.lang === "fr";
const locale = isFrench ? "fr-FR" : "en-US";
const publicationDate = article.data.date.toLocaleDateString(locale, {
  day: "2-digit",
  month: "long",
  year: "numeric"
});
const updatedDate = (article.data.updated ?? article.data.date).toLocaleDateString(locale, {
  day: "2-digit",
  month: "long",
  year: "numeric"
});
const readingTimeMinutes = estimateReadingTimeMinutes(article.body);
const readingTimeLabel = isFrench ? `${readingTimeMinutes} min de lecture` : `${readingTimeMinutes} min read`;

const allArticles = await getCollection("articles", ({ data }) => data.lang === article.data.lang);
const allGuides = await getCollection("guides", ({ data }) => data.lang === article.data.lang);
const allVideos = await getCollection("videos", ({ data }) => data.lang === article.data.lang);
const toolReviews = await getCollection("toolReviews", ({ data }) => data.lang === article.data.lang);

const relatedArticles = getRelatedArticles(
  article,
  allArticles.filter((entry) => entry.slug !== article.slug),
  3
);

const relatedGuides = getRelatedGuidesForArticle(article, allGuides, 3);
const relatedVideos = getRelatedVideosForArticle(article, allVideos, 3);

const linkedVideo = article.data.linkedVideoSlug
  ? allVideos.find((video) => video.slug === article.data.linkedVideoSlug)
  : undefined;

const canLinkYoutube = isConfiguredExternalUrl(youtubeUrl);
const youtubeButtonHref = canLinkYoutube ? youtubeUrl : withBase("/contact/");

const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const articleCategory = getArticleCategory(article.data.tags);
const takeaways = getArticleKeyTakeaways(article, tocHeadings);

const relatedTools = getRelatedToolsForArticle(article, resourcesCatalog, 5);
const miniTopTools = relatedTools.slice(0, 4);

const reviewByResourceKey = new Map(toolReviews.map((review) => [review.data.resourceKey, review]));

const getToolSecondaryPath = (resourceKey: string): string => {
  const review = reviewByResourceKey.get(resourceKey);
  if (review) {
    return withBase(`/outils/avis/${review.slug}/`);
  }

  const resource = resourcesCatalog.find((entry) => entry.key === resourceKey);
  if (resource) {
    const reviewPath = getResourceReviewPath(resource);
    if (reviewPath) {
      return reviewPath;
    }
  }

  return withBase(`/outils/${resourceKey}/`);
};

const relatedToolItems = relatedTools.map((tool) => ({
  key: tool.key,
  name: tool.name,
  description: tool.description,
  badge: tool.badge,
  priceTier: tool.priceTier,
  wizardScore: tool.wizardScore,
  bestFor: tool.bestFor,
  primaryHref: getResourceOutboundPath(tool.key),
  secondaryHref: getToolSecondaryPath(tool.key),
  secondaryLabel: reviewByResourceKey.has(tool.key) ? "Voir l’avis" : "Voir la fiche"
}));

const sidebarToolItems = relatedToolItems.slice(0, 4);
const topToolsKeys = miniTopTools.map((tool) => tool.key);
---

<BaseLayout
  canonicalPath={`/articles/${article.slug}/`}
  title={`${article.data.title} | ${brandDisplayName}`}
  description={article.data.summary}
  type="article"
  lang={article.data.lang}
>
  <section class="section">
    <div class="container surface-hero article-hero">
      <Breadcrumbs
        items={[
          { label: isFrench ? "Accueil" : "Home", href: isFrench ? "/" : "/en/" },
          { label: "Blog", href: "/articles/" },
          { label: article.data.title }
        ]}
      />

      <p class="eyebrow">{articleCategory.label}</p>
      <h1>{article.data.title}</h1>
      <p class="hero-deck">{article.data.summary}</p>

      <p class="small muted">
        {publicationDate} · {isFrench ? "Mis à jour" : "Updated"} {updatedDate} · {readingTimeLabel} · {article.data.status === "published" ? (isFrench ? "Publié" : "Published") : "Coming soon"}
      </p>

      <TagList tags={article.data.tags} />

      <div class="hero-actions">
        <button type="button" class="button button-ghost" data-open-search-palette>{isFrench ? "Rechercher" : "Search"}</button>
        <a class="button button-secondary" href={withBase("/downloads/")}>{isFrench ? "Pack gratuit" : "Free pack"}</a>
      </div>

      <ShareButtons canonicalPath={`/articles/${article.slug}/`} title={article.data.title} lang={article.data.lang} />

      <CalloutBox title="L’essentiel à retenir" variant="key-takeaways" items={takeaways} />
    </div>
  </section>

  {
    tocHeadings.length >= 3 && (
      <section class="section mobile-toc-wrap">
        <div class="container mobile-toc-shell">
          <TableOfContents headings={tocHeadings} title={isFrench ? "Sommaire" : "Outline"} mobileCollapsible={true} />
        </div>
      </section>
    )
  }

  <section class="section article-content-section">
    <div class="container article-layout">
      <article class="surface article-body prose enhanced-content">
        <Content />
        <ContextualCtaBanner />
      </article>

      <aside class="article-aside">
        {
          tocHeadings.length >= 3 && <TableOfContents headings={tocHeadings} title={isFrench ? "Sommaire" : "Outline"} />
        }

        <div class="surface aside-tools">
          <RelatedTools
            title="Top outils liés"
            description="Sélection rapide pour appliquer les points de l’article."
            items={sidebarToolItems}
            compact={true}
          />
          <div class="aside-cta-row">
            <a class="button button-primary" href={withBase("/outils/")}>Toolbox</a>
            <a class="button button-secondary" href={withBase("/downloads/")}>Pack gratuit</a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container surface video-block">
      <h2>{isFrench ? "Bloc vidéo" : "Video block"}</h2>
      {
        article.data.youtubeId ? (
          <>
            <iframe
              src={`https://www.youtube-nocookie.com/embed/${article.data.youtubeId}`}
              title={article.data.title}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            />
            <a
              class="button button-secondary"
              href={`https://www.youtube.com/watch?v=${article.data.youtubeId}`}
              target="_blank"
              rel="noopener nofollow"
            >
              {isFrench ? "Voir la vidéo" : "Watch video"}
            </a>
          </>
        ) : (
          <>
            <p class="small muted">{isFrench ? "Vidéo à venir" : "Video coming soon"}</p>
            <a
              class="button button-secondary"
              href={youtubeButtonHref}
              target={canLinkYoutube ? "_blank" : undefined}
              rel={canLinkYoutube ? "noopener nofollow" : undefined}
            >
              {isFrench ? "S’abonner sur YouTube" : "Subscribe on YouTube"}
            </a>
            {
              linkedVideo && (
                <p class="small muted">
                  {isFrench ? "Vidéo liée déjà disponible:" : "Related video already available:"} <a href={withBase(`/videos/${linkedVideo.slug}/`)}>{linkedVideo.data.title}</a>
                </p>
              )
            }
          </>
        )
      }
    </div>
  </section>

  <section class="section related-tools-section">
    <div class="container surface related-tools-wrap">
      <RelatedTools
        title="Outils liés à cet article"
        description="Sélection automatique basée sur le sujet, les tags et les objectifs de l’article."
        items={relatedToolItems}
      />
    </div>
  </section>

  {(relatedArticles.length > 0 || relatedGuides.length > 0 || relatedVideos.length > 0) && (
    <section class="section related-section">
      <div class="container grid related-grid">
        {
          relatedArticles.length > 0 && (
            <article class="surface related-block">
              <h2>{isFrench ? "Articles recommandés" : "Recommended articles"}</h2>
              <ul>
                {relatedArticles.map((entry) => <li><a href={withBase(`/articles/${entry.slug}/`)}>{entry.data.title}</a></li>)}
              </ul>
            </article>
          )
        }

        {
          relatedGuides.length > 0 && (
            <article class="surface related-block">
              <h2>{isFrench ? "Guides complémentaires" : "Related guides"}</h2>
              <ul>
                {relatedGuides.map((entry) => <li><a href={withBase(`/guides/${entry.slug}/`)}>{entry.data.title}</a></li>)}
              </ul>
            </article>
          )
        }

        {
          relatedVideos.length > 0 && (
            <article class="surface related-block">
              <h2>{isFrench ? "Vidéos à enchaîner" : "Related videos"}</h2>
              <ul>
                {relatedVideos.map((entry) => <li><a href={withBase(`/videos/${entry.slug}/`)}>{entry.data.title}</a></li>)}
              </ul>
            </article>
          )
        }
      </div>
    </section>
  )}

  <section class="section article-bottom">
    <div class="container article-bottom-grid">
      <div class="author-wrap">
        <div class="author-mascot-row">
          <Mascot action="present" size="sm" />
          <p class="small muted">Présence éditoriale TAC</p>
        </div>
        <AuthorCard lang={article.data.lang} />
      </div>
      <TopToolsStrip
        title="Top outils"
        description="Version courte pour passer de la lecture à l’action."
        limit={4}
        keys={topToolsKeys}
      />
    </div>
  </section>

  <ContentEnhancements contentSelector=".article-body" lang={article.data.lang} />
</BaseLayout>

<style>
  .article-hero {
    padding: clamp(1.1rem, 3vw, 2rem);
    display: grid;
    gap: 0.75rem;
  }

  .hero-deck {
    max-width: 80ch;
    font-size: clamp(1.08rem, 1.5vw, 1.2rem);
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .mobile-toc-wrap {
    padding-top: 0;
    display: none;
  }

  .mobile-toc-shell {
    max-width: var(--content-wide);
  }

  .article-content-section {
    padding-top: 0;
  }

  .article-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(290px, 340px);
    gap: 1.05rem;
    align-items: start;
  }

  .article-body {
    padding: clamp(1.35rem, 3vw, 2.3rem);
    min-width: 0;
  }

  .article-aside {
    display: grid;
    gap: 0.85rem;
    align-self: start;
  }

  .aside-tools {
    padding: 0.9rem;
    display: grid;
    gap: 0.7rem;
    border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--border));
    background: linear-gradient(155deg, #fbf8f0 0%, #eff2e9 100%);
  }

  .aside-cta-row {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .video-block {
    padding: 1.2rem;
    display: grid;
    gap: 0.75rem;
  }

  .video-block iframe {
    width: 100%;
    min-height: clamp(220px, 45vw, 520px);
    border: 0;
    border-radius: var(--radius-2);
  }

  .related-tools-section {
    padding-top: 0;
  }

  .related-tools-wrap {
    padding: 1rem;
  }

  .related-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .related-block {
    padding: 1rem;
    display: grid;
    gap: 0.4rem;
  }

  .related-block h2 {
    margin: 0;
    font-size: 1.35rem;
  }

  .related-block ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--text-soft);
  }

  .related-block a {
    text-decoration: none;
  }

  .related-block a:hover {
    text-decoration: underline;
  }

  .article-bottom {
    padding-top: 0;
  }

  .article-bottom-grid {
    display: grid;
    gap: 0.8rem;
  }

  .author-wrap {
    display: grid;
    gap: 0.55rem;
  }

  .author-mascot-row {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .author-mascot-row p {
    margin: 0;
  }

  @media (max-width: 1080px) {
    .article-layout {
      grid-template-columns: 1fr;
    }

    .article-aside {
      position: static;
      display: none;
    }

    .mobile-toc-wrap {
      display: block;
    }
  }

  @media (max-width: 980px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
