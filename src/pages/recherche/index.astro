---
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import TopToolsStrip from "../../components/TopToolsStrip.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/links";

const searchIndexUrl = withBase("/search-index.json");
const baseUrl = withBase("/");
---

<BaseLayout
  canonicalPath="/recherche/"
  title="Recherche | Thésard Au Calme"
  description="Recherche locale instantanée dans les articles, guides, vidéos, hubs et avis outils pour trouver rapidement le bon contenu."
>
  <section class="section">
    <div class="container prose">
      <Breadcrumbs items={[{ label: "Accueil", href: "/" }, { label: "Recherche" }]} />
      <p class="eyebrow">Recherche</p>
      <h1>Trouver rapidement le bon contenu</h1>
      <p>
        Index local statique: articles, guides, vidéos, pages hubs et avis outils. Le moteur reste léger, base-path safe et utilisable au clavier.
      </p>
    </div>
  </section>

  <section class="section search-main-section">
    <div
      class="container surface search-block"
      data-search-root
      data-search-index-url={searchIndexUrl}
      data-base-url={baseUrl}
    >
      <label for="search-input">Rechercher par mot-clé, tag ou thème</label>
      <input id="search-input" name="q" type="search" placeholder="ex: zotero, soutenance, visa, stack" autocomplete="off" />

      <div class="filters-grid">
        <div class="filter-group">
          <p class="small muted">Type de contenu</p>
          <div class="chip-row" id="type-filters">
            <button type="button" class="filter-chip is-active" data-filter="type" data-value="article">Articles</button>
            <button type="button" class="filter-chip is-active" data-filter="type" data-value="guide">Guides</button>
            <button type="button" class="filter-chip is-active" data-filter="type" data-value="video">Vidéos</button>
            <button type="button" class="filter-chip is-active" data-filter="type" data-value="tool-review">Avis</button>
            <button type="button" class="filter-chip is-active" data-filter="type" data-value="page">Pages</button>
          </div>
        </div>

        <div class="filter-group">
          <p class="small muted">Langue</p>
          <div class="chip-row" id="lang-filters">
            <button type="button" class="filter-chip is-active" data-filter="lang" data-value="fr">FR</button>
            <button type="button" class="filter-chip" data-filter="lang" data-value="en">EN</button>
          </div>
        </div>
      </div>

      <p id="search-status" class="small muted">Chargement de l’index…</p>
      <div id="search-results" class="search-groups"></div>
    </div>
  </section>

  <section class="section top-tools-search">
    <div class="container">
      <TopToolsStrip
        title="Top outils à ouvrir après la recherche"
        description="Une sélection courte pour passer de la découverte à l'action en moins de 10 minutes."
        limit={8}
      />
    </div>
  </section>
</BaseLayout>

<script type="module">
  import {
    groupMatchesByType,
    normalizeSearchValue,
    orderedSearchTypes,
    runSearch,
    searchTypeLabel,
    toBasePath
  } from "../../lib/search-client";

  (() => {
    const searchRoot = document.querySelector("[data-search-root]");
    if (!(searchRoot instanceof HTMLElement)) {
      return;
    }

    const searchIndexUrl = searchRoot.dataset.searchIndexUrl || "";
    const baseUrl = searchRoot.dataset.baseUrl || "/";

    const searchInput = document.getElementById("search-input");
    const searchStatus = document.getElementById("search-status");
    const searchResults = document.getElementById("search-results");
    const typeButtons = Array.from(document.querySelectorAll('[data-filter="type"]'));
    const langButtons = Array.from(document.querySelectorAll('[data-filter="lang"]'));

    if (!(searchInput instanceof HTMLInputElement) || !(searchStatus instanceof HTMLElement) || !(searchResults instanceof HTMLElement)) {
      return;
    }

    const typeGroupLabel = {
      article: "Articles",
      guide: "Guides",
      video: "Vidéos",
      "tool-review": "Avis outils",
      page: "Pages"
    };

    const formatDate = (isoDate) =>
      new Date(isoDate).toLocaleDateString("fr-FR", {
        day: "2-digit",
        month: "long",
        year: "numeric"
      });

    const selectedTypes = new Set(orderedSearchTypes);
    const selectedLangs = new Set(["fr"]);
    let index = [];
    let activeResultLinkIndex = -1;

    const syncButtons = (buttons, selectedSet) => {
      buttons.forEach((button) => {
        const value = button.dataset.value;
        button.classList.toggle("is-active", selectedSet.has(value));
        button.setAttribute("aria-pressed", selectedSet.has(value) ? "true" : "false");
      });
    };

    const toggleSelectedValue = (selectedSet, value) => {
      if (selectedSet.has(value)) {
        if (selectedSet.size > 1) {
          selectedSet.delete(value);
        }
      } else {
        selectedSet.add(value);
      }
    };

    const updateUrlQuery = (query) => {
      const url = new URL(window.location.href);
      if (query) {
        url.searchParams.set("q", query);
      } else {
        url.searchParams.delete("q");
      }
      window.history.replaceState({}, "", url);
    };

    const buildCard = (match) => {
      const entry = match.entry;
      const article = document.createElement("article");
      article.className = "card result-card";

      const metaBits = [searchTypeLabel[entry.type] ?? "Contenu"];
      if (entry.date) {
        metaBits.push(formatDate(entry.date));
      }

      const tags = entry.tags.length > 0 ? entry.tags.map((tag) => `#${tag}`).join(" · ") : "";

      article.innerHTML = `
        <p class="small muted">${metaBits.join(" · ")}</p>
        <h3><a href="${toBasePath(baseUrl, entry.path)}" data-result-link>${entry.title}</a></h3>
        <p>${entry.summary}</p>
        ${tags ? `<p class="small muted">${tags}</p>` : ""}
      `;

      return article;
    };

    const updateActiveLink = (nextIndex) => {
      const links = [...searchResults.querySelectorAll("a[data-result-link]")];
      if (links.length === 0) {
        activeResultLinkIndex = -1;
        return;
      }

      activeResultLinkIndex = Math.max(0, Math.min(links.length - 1, nextIndex));

      links.forEach((link, indexValue) => {
        link.classList.toggle("is-active-result", indexValue === activeResultLinkIndex);
      });

      const activeLink = links[activeResultLinkIndex];
      if (activeLink instanceof HTMLElement) {
        activeLink.focus();
        activeLink.scrollIntoView({ block: "nearest" });
      }
    };

    const renderResults = (matches, query) => {
      searchResults.innerHTML = "";
      activeResultLinkIndex = -1;

      if (!query) {
        searchStatus.textContent = "Entrer au moins 2 caractères pour lancer la recherche.";
        return;
      }

      if (matches.length === 0) {
        searchStatus.textContent = "Aucun résultat. Essayer une formulation plus large.";
        return;
      }

      const groupedEntries = groupMatchesByType(matches);

      let renderedCount = 0;

      orderedSearchTypes.forEach((type) => {
        const groupItems = groupedEntries[type];
        if (!groupItems || groupItems.length === 0) {
          return;
        }

        const groupSection = document.createElement("section");
        groupSection.className = "result-group";

        const heading = document.createElement("h2");
        heading.textContent = `${typeGroupLabel[type]} (${groupItems.length})`;
        groupSection.appendChild(heading);

        const groupGrid = document.createElement("div");
        groupGrid.className = "grid result-group-grid";
        groupItems.forEach((match) => groupGrid.appendChild(buildCard(match)));

        groupSection.appendChild(groupGrid);
        searchResults.appendChild(groupSection);
        renderedCount += groupItems.length;
      });

      searchStatus.textContent = `${renderedCount} résultat(s) trouvés.`;
    };

    const applySearch = () => {
      const query = normalizeSearchValue(searchInput.value);
      updateUrlQuery(query);

      if (query.length < 2) {
        renderResults([], "");
        return;
      }

      const matches = runSearch(index, query, {
        types: selectedTypes,
        langs: selectedLangs,
        limit: 80
      });

      renderResults(matches, query);
    };

    typeButtons.forEach((button) => {
      button.addEventListener("click", () => {
        toggleSelectedValue(selectedTypes, button.dataset.value);
        syncButtons(typeButtons, selectedTypes);
        applySearch();
      });
    });

    langButtons.forEach((button) => {
      button.addEventListener("click", () => {
        toggleSelectedValue(selectedLangs, button.dataset.value);
        syncButtons(langButtons, selectedLangs);
        applySearch();
      });
    });

    fetch(searchIndexUrl)
      .then((response) => {
        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }
        return response.json();
      })
      .then((entries) => {
        index = entries;
        syncButtons(typeButtons, selectedTypes);
        syncButtons(langButtons, selectedLangs);

        const initialQuery = normalizeSearchValue(new URL(window.location.href).searchParams.get("q") || "");
        if (initialQuery) {
          searchInput.value = initialQuery;
        }
        applySearch();
      })
      .catch(() => {
        searchStatus.textContent = "Impossible de charger l’index de recherche.";
      });

    searchInput.addEventListener("input", applySearch);

    searchInput.addEventListener("keydown", (event) => {
      if (event.key === "ArrowDown") {
        event.preventDefault();
        updateActiveLink(activeResultLinkIndex + 1);
      }

      if (event.key === "ArrowUp") {
        event.preventDefault();
        updateActiveLink(activeResultLinkIndex - 1);
      }
    });

    searchResults.addEventListener("keydown", (event) => {
      if (event.key === "ArrowDown") {
        event.preventDefault();
        updateActiveLink(activeResultLinkIndex + 1);
      }

      if (event.key === "ArrowUp") {
        event.preventDefault();
        updateActiveLink(activeResultLinkIndex - 1);
      }
    });

    document.addEventListener("keydown", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) {
        return;
      }

      const isTypingContext =
        target.tagName === "INPUT" ||
        target.tagName === "TEXTAREA" ||
        target.isContentEditable;

      if (!isTypingContext && event.key === "/") {
        event.preventDefault();
        searchInput.focus();
      }
    });
  })();
</script>

<style>
  .search-main-section {
    padding-top: 0;
  }

  .search-block {
    padding: 1.2rem;
    display: grid;
    gap: 0.8rem;
  }

  .search-block input {
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    padding: 0.72rem 0.9rem;
    font: inherit;
    background: #fff;
  }

  .filters-grid {
    display: grid;
    gap: 0.75rem;
  }

  .chip-row {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .filter-chip {
    border: 1px solid var(--border);
    background: #fff;
    border-radius: var(--radius-pill);
    padding: 0.28rem 0.72rem;
    color: var(--text-soft);
    cursor: pointer;
    font: inherit;
    font-size: 0.86rem;
  }

  .filter-chip.is-active {
    background: #eef7f8;
    color: var(--brand-accent);
    border-color: color-mix(in srgb, var(--brand-accent) 32%, var(--border));
  }

  .search-groups {
    margin-top: 0.35rem;
    display: grid;
    gap: 1rem;
  }

  #search-results :global(.result-group) {
    display: grid;
    gap: 0.5rem;
  }

  #search-results :global(.result-group h2) {
    margin: 0;
    font-size: 1.2rem;
  }

  #search-results :global(.result-group-grid) {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  #search-results :global(.result-card) {
    display: grid;
    gap: 0.45rem;
  }

  #search-results :global(.result-card h3) {
    margin: 0;
  }

  #search-results :global(.result-card a) {
    text-decoration: none;
  }

  #search-results :global(.result-card a:hover),
  #search-results :global(.result-card a.is-active-result) {
    text-decoration: underline;
    color: var(--brand-accent);
  }

  .top-tools-search {
    padding-top: 0;
  }

  @media (max-width: 960px) {
    #search-results :global(.result-group-grid) {
      grid-template-columns: 1fr;
    }
  }
</style>
